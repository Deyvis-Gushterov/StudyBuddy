@page
@model StudyBuddy.Pages.Notes.IndexModel
@{
    ViewData["Title"] = "Notes";
}

<style>
    .notes-toolbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 1rem;
        margin-bottom: 2rem;
        flex-wrap: wrap;
    }

    .notes-search {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        background: var(--white);
        border: 1.5px solid var(--border);
        border-radius: 10px;
        padding: 0.5rem 1rem;
        flex: 1;
        max-width: 380px;
        transition: border-color 0.15s;
    }

    .notes-search:focus-within { border-color: var(--navy); }

    .notes-search svg {
        width: 16px;
        height: 16px;
        stroke: var(--text-muted);
        flex-shrink: 0;
    }

    .notes-search input {
        border: none;
        outline: none;
        font-family: var(--font-body);
        font-size: 0.9rem;
        color: var(--text-dark);
        background: transparent;
        width: 100%;
    }

    .notes-search input::placeholder { color: var(--text-muted); }

    .notes-filters {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
    }

    .filter-btn {
        font-family: var(--font-body);
        font-size: 0.8rem;
        font-weight: 500;
        color: var(--text-muted);
        background: var(--white);
        border: 1.5px solid var(--border);
        padding: 0.35rem 0.9rem;
        border-radius: 20px;
        cursor: pointer;
        transition: all 0.15s;
    }

    .filter-btn:hover, .filter-btn.active {
        color: var(--navy);
        border-color: var(--navy);
        background: var(--cream);
    }

    .notes-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
        gap: 1.25rem;
    }

    .note-card {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1.5rem;
        transition: all 0.2s ease;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
        text-decoration: none;
        color: inherit;
        position: relative;
        overflow: hidden;
    }

    .note-card::before {
        content: '';
        position: absolute;
        top: 0;
        left: 0;
        right: 0;
        height: 3px;
        background: var(--navy);
        transform: scaleX(0);
        transition: transform 0.2s ease;
        transform-origin: left;
    }

    .note-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 30px rgba(27,42,74,0.1);
        border-color: transparent;
        text-decoration: none;
        color: inherit;
    }

    .note-card:hover::before { transform: scaleX(1); }

    .note-card-header {
        display: flex;
        align-items: flex-start;
        justify-content: space-between;
        gap: 0.5rem;
    }

    .note-subject {
        font-size: 0.72rem;
        font-weight: 600;
        color: var(--amber);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .note-likes {
        display: flex;
        align-items: center;
        gap: 4px;
        font-size: 0.8rem;
        color: var(--text-muted);
    }

    .note-likes svg {
        width: 14px;
        height: 14px;
        stroke: var(--text-muted);
    }

    .note-title {
        font-family: var(--font-heading);
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--navy);
        line-height: 1.3;
        margin: 0;
    }

    .note-excerpt {
        font-size: 0.85rem;
        color: var(--text-muted);
        line-height: 1.6;
        margin: 0;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .note-card-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: 0.75rem;
        border-top: 1px solid var(--border);
        margin-top: auto;
    }

    .note-author {
        display: flex;
        align-items: center;
        gap: 7px;
    }

    .note-avatar {
        width: 24px;
        height: 24px;
        background: var(--navy);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 9px;
        font-weight: 600;
        color: var(--amber);
    }

    .note-author-name {
        font-size: 0.8rem;
        font-weight: 500;
        color: var(--text-muted);
    }

    .note-date {
        font-size: 0.75rem;
        color: var(--text-muted);
    }

    /* Empty state */
    .empty-state {
        text-align: center;
        padding: 5rem 2rem;
        grid-column: 1 / -1;
    }

    .empty-icon {
        font-size: 3rem;
        margin-bottom: 1rem;
    }

    .empty-state h3 {
        font-size: 1.25rem;
        color: var(--navy);
        margin-bottom: 0.5rem;
    }

    .empty-state p {
        color: var(--text-muted);
        font-size: 0.9rem;
        margin-bottom: 1.5rem;
    }

    @@media (max-width: 600px) {
        .notes-toolbar { flex-direction: column; align-items: stretch; }
        .notes-search { max-width: 100%; }
        .notes-grid { grid-template-columns: 1fr; }
    }
</style>

<!-- Page Header -->
<div class="sb-page-header">
    <div>
        <h1>Notes</h1>
        <p>Browse and discover notes shared by the community</p>
    </div>
    <a class="btn-sb-primary" asp-page="/Notes/Create">+ New Note</a>
</div>

<!-- Toolbar -->
<div class="notes-toolbar">
    <div class="notes-search">
        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
            <circle cx="11" cy="11" r="8"/><path d="m21 21-4.35-4.35"/>
        </svg>
        <input type="text" id="searchInput" placeholder="Search notes by topic or subject..." />
    </div>
    <div class="notes-filters">
        <button class="filter-btn active" data-filter="all">All</button>
        <button class="filter-btn" data-filter="Math">Math</button>
        <button class="filter-btn" data-filter="Science">Science</button>
        <button class="filter-btn" data-filter="History">History</button>
        <button class="filter-btn" data-filter="Literature">Literature</button>
        <button class="filter-btn" data-filter="Other">Other</button>
    </div>
</div>

<!-- Notes Grid -->
<div class="notes-grid" id="notesGrid">
    @if (!Model.Notes.Any())
    {
        <div class="empty-state">
            <div class="empty-icon">📝</div>
            <h3>No notes yet</h3>
            <p>Be the first to share your notes with the community!</p>
            <a class="btn-sb-primary" asp-page="/Notes/Create">Share your first note</a>
        </div>
    }
    else
    {
        @foreach (var note in Model.Notes)
        {
            <a class="note-card" asp-page="/Notes/Details" asp-route-id="@note.Id" data-subject="@note.Subject">
                <div class="note-card-header">
                    <span class="note-subject">@note.Subject</span>
                    <div class="note-likes">
                        <svg fill="none" stroke="currentColor" viewBox="0 0 24 24">
                            <path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/>
                        </svg>
                        @note.Likes
                    </div>
                </div>
                <h3 class="note-title">@note.Topic</h3>
                <p class="note-excerpt">@note.BriefExplanation</p>
                <div class="note-card-footer">
                    <div class="note-author">
                        <div class="note-avatar">
                            @(note.Creator?.FirstName?.Substring(0, 1).ToUpper())@(note.Creator?.LastName?.Substring(0, 1).ToUpper())
                        </div>
                        <span class="note-author-name">@note.Creator?.FirstName @note.Creator?.LastName</span>
                    </div>
                    <span class="note-date">@note.DateOfCreation.ToString("MMM dd, yyyy")</span>
                </div>
            </a>
        }
    }
</div>

@section Scripts {
<script>
    const searchInput = document.getElementById('searchInput');
    const filterBtns = document.querySelectorAll('.filter-btn');
    const cards = document.querySelectorAll('.note-card[data-subject]');
    let activeFilter = 'all';

    function applyFilters() {
        const query = searchInput.value.toLowerCase();
        cards.forEach(card => {
            const subject = card.dataset.subject?.toLowerCase() || '';
            const title = card.querySelector('.note-title')?.textContent.toLowerCase() || '';
            const excerpt = card.querySelector('.note-excerpt')?.textContent.toLowerCase() || '';
            const matchesSearch = !query || title.includes(query) || excerpt.includes(query) || subject.includes(query);
            const matchesFilter = activeFilter === 'all' || subject === activeFilter.toLowerCase();
            card.style.display = matchesSearch && matchesFilter ? 'flex' : 'none';
        });
    }

    searchInput.addEventListener('input', applyFilters);

    filterBtns.forEach(btn => {
        btn.addEventListener('click', () => {
            filterBtns.forEach(b => b.classList.remove('active'));
            btn.classList.add('active');
            activeFilter = btn.dataset.filter;
            applyFilters();
        });
    });
</script>
}

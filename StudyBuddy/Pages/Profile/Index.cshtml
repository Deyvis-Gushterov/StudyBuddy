@page
@model StudyBuddy.Pages.UserProfile.IndexModel
@{
    ViewData["Title"] = Model.ProfileUser != null
        ? $"{Model.ProfileUser.FirstName} {Model.ProfileUser.LastName}"
        : "Profile";
}

<style>
    /* ── Profile Header ── */
    .profile-header {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
        box-shadow: var(--card-shadow);
        margin-bottom: 2rem;
    }

    .profile-cover {
        height: 120px;
        background: linear-gradient(135deg, #1B2A4A 0%, #243659 50%, #D4890A 100%);
        position: relative;
    }

    .profile-header-body {
        padding: 0 2rem 2rem;
        display: flex;
        align-items: flex-end;
        justify-content: space-between;
        gap: 1.5rem;
        flex-wrap: wrap;
    }

    .profile-avatar-wrap {
        margin-top: -40px;
        position: relative;
    }

    .profile-avatar {
        width: 80px;
        height: 80px;
        background: var(--white);
        border-radius: 50%;
        border: 4px solid var(--white);
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: var(--font-heading);
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--amber);
        background: var(--navy);
        box-shadow: 0 4px 12px rgba(27,42,74,0.2);
    }

    .profile-info { flex: 1; padding-top: 1rem; }

    .profile-name {
        font-family: var(--font-heading);
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--navy);
        margin: 0 0 0.25rem;
    }

    .profile-meta {
        display: flex;
        gap: 0.75rem;
        flex-wrap: wrap;
        margin-bottom: 0.75rem;
    }

    .profile-meta-item {
        font-size: 0.8rem;
        color: var(--text-muted);
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .profile-stats {
        display: flex;
        gap: 1.5rem;
        flex-wrap: wrap;
    }

    .profile-stat { text-align: center; }

    .profile-stat-num {
        font-family: var(--font-heading);
        font-size: 1.25rem;
        font-weight: 700;
        color: var(--navy);
        display: block;
    }

    .profile-stat-label {
        font-size: 0.72rem;
        color: var(--text-muted);
    }

    .profile-stat-divider {
        width: 1px;
        height: 32px;
        background: var(--border);
        align-self: center;
    }

    .profile-actions {
        display: flex;
        gap: 0.75rem;
        align-items: center;
        padding-top: 1rem;
    }

    .btn-follow {
        font-family: var(--font-body);
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--white);
        background: var(--navy);
        border: 1.5px solid var(--navy);
        padding: 0.5rem 1.5rem;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.15s;
    }

    .btn-follow:hover { background: var(--navy-light); }

    .btn-unfollow {
        font-family: var(--font-body);
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--navy);
        background: var(--white);
        border: 1.5px solid var(--border);
        padding: 0.5rem 1.5rem;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.15s;
    }

    .btn-unfollow:hover { border-color: #EF4444; color: #EF4444; }

    /* ── Tabs ── */
    .profile-tabs {
        display: flex;
        gap: 0.25rem;
        border-bottom: 2px solid var(--border);
        margin-bottom: 2rem;
    }

    .tab-btn {
        font-family: var(--font-body);
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--text-muted);
        background: transparent;
        border: none;
        padding: 0.75rem 1.25rem;
        cursor: pointer;
        border-bottom: 2px solid transparent;
        margin-bottom: -2px;
        transition: all 0.15s;
        white-space: nowrap;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .tab-btn:hover { color: var(--navy); }
    .tab-btn.active { color: var(--navy); border-bottom-color: var(--navy); font-weight: 600; }

    .tab-count {
        background: var(--cream);
        border: 1px solid var(--border);
        font-size: 0.7rem;
        font-weight: 600;
        padding: 1px 7px;
        border-radius: 20px;
        color: var(--text-muted);
    }

    .tab-btn.active .tab-count { background: var(--navy); border-color: var(--navy); color: var(--white); }

    .tab-panel { display: none; }
    .tab-panel.active { display: block; }

    /* ── Notes Grid ── */
    .profile-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.25rem;
    }

    .profile-note-card {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1.25rem;
        transition: all 0.2s ease;
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
        text-decoration: none;
        color: inherit;
    }

    .profile-note-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(27,42,74,0.1);
        text-decoration: none;
        color: inherit;
    }

    .card-subject {
        font-size: 0.7rem;
        font-weight: 600;
        color: var(--amber);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .card-title {
        font-family: var(--font-heading);
        font-size: 1rem;
        font-weight: 600;
        color: var(--navy);
        margin: 0;
        line-height: 1.3;
    }

    .card-excerpt {
        font-size: 0.82rem;
        color: var(--text-muted);
        line-height: 1.5;
        margin: 0;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .card-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: 0.6rem;
        border-top: 1px solid var(--border);
        margin-top: auto;
        font-size: 0.75rem;
        color: var(--text-muted);
    }

    /* ── Blog List ── */
    .profile-blog-card {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1.25rem 1.5rem;
        margin-bottom: 1rem;
        display: flex;
        gap: 1rem;
        align-items: flex-start;
        transition: all 0.2s;
        text-decoration: none;
        color: inherit;
    }

    .profile-blog-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(27,42,74,0.1);
        text-decoration: none;
        color: inherit;
    }

    .profile-blog-content { flex: 1; }

    .profile-blog-title {
        font-family: var(--font-heading);
        font-size: 1.05rem;
        font-weight: 600;
        color: var(--navy);
        margin: 0 0 0.4rem;
        line-height: 1.3;
    }

    .profile-blog-summary {
        font-size: 0.82rem;
        color: var(--text-muted);
        margin: 0 0 0.6rem;
        line-height: 1.5;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .profile-blog-meta {
        display: flex;
        gap: 1rem;
        font-size: 0.75rem;
        color: var(--text-muted);
    }

    /* ── Followers Grid ── */
    .followers-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(180px, 1fr));
        gap: 1rem;
    }

    .follower-card {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1.25rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        text-align: center;
        text-decoration: none;
        color: inherit;
        transition: all 0.2s;
    }

    .follower-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 16px rgba(27,42,74,0.08);
        text-decoration: none;
        color: inherit;
    }

    .follower-avatar {
        width: 48px;
        height: 48px;
        background: var(--navy);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        font-weight: 700;
        color: var(--amber);
    }

    .follower-name { font-weight: 600; font-size: 0.875rem; color: var(--navy); }
    .follower-nationality { font-size: 0.75rem; color: var(--text-muted); }

    /* ── Empty State ── */
    .profile-empty {
        text-align: center;
        padding: 4rem 2rem;
        grid-column: 1 / -1;
    }

    .profile-empty-icon { font-size: 2.5rem; margin-bottom: 0.75rem; }
    .profile-empty h3 { font-size: 1.1rem; color: var(--navy); margin-bottom: 0.4rem; }
    .profile-empty p { font-size: 0.875rem; color: var(--text-muted); margin: 0; }

    @@media (max-width: 768px) {
        .profile-header-body { flex-direction: column; align-items: flex-start; }
        .profile-grid { grid-template-columns: 1fr; }
        .followers-grid { grid-template-columns: repeat(2, 1fr); }
    }
</style>

@if (Model.ProfileUser == null)
{
    <div class="sb-alert sb-alert-danger">User not found.</div>
    return;
}

<!-- Profile Header -->
<div class="profile-header">
    <div class="profile-cover"></div>
    <div class="profile-header-body">
        <div style="display:flex; gap:1.5rem; align-items:flex-end; flex-wrap:wrap;">
            <div class="profile-avatar-wrap">
                <div class="profile-avatar">
                    @(Model.ProfileUser.FirstName?.Substring(0, 1).ToUpper())@(Model.ProfileUser.LastName?.Substring(0, 1).ToUpper())
                </div>
            </div>
            <div class="profile-info">
                <h1 class="profile-name">
                    @Model.ProfileUser.FirstName @Model.ProfileUser.LastName
                    @if (Model.IsOwnProfile)
                    {
                        <span style="font-size:0.75rem; font-weight:500; color:var(--text-muted); font-family:var(--font-body);"> (You)</span>
                    }
                </h1>
                <div class="profile-meta">
                    @if (!string.IsNullOrEmpty(Model.ProfileUser.Nationality))
                    {
                        <span class="profile-meta-item">🌍 @Model.ProfileUser.Nationality</span>
                    }
                    @if (Model.ProfileUser.Age > 0)
                    {
                        <span class="profile-meta-item">🎂 @Model.ProfileUser.Age years old</span>
                    }
                    <span class="profile-meta-item">📧 @Model.ProfileUser.Email</span>
                </div>
            </div>
        </div>

        <div style="display:flex; flex-direction:column; gap:1rem; align-items:flex-end;">
            <div class="profile-stats">
                <div class="profile-stat">
                    <span class="profile-stat-num">@Model.UserNotes.Count</span>
                    <div class="profile-stat-label">Notes</div>
                </div>
                <div class="profile-stat-divider"></div>
                <div class="profile-stat">
                    <span class="profile-stat-num">@Model.UserBlogs.Count</span>
                    <div class="profile-stat-label">Blogs</div>
                </div>
                <div class="profile-stat-divider"></div>
                <div class="profile-stat">
                    <span class="profile-stat-num">@Model.Followers.Count</span>
                    <div class="profile-stat-label">Followers</div>
                </div>
            </div>

            @if (!Model.IsOwnProfile)
            {
                <div class="profile-actions">
                    @if (Model.IsFollowing)
                    {
                        <form method="post" asp-page-handler="Unfollow">
                            <input type="hidden" name="userId" value="@Model.ProfileUser.Id" />
                            <button type="submit" class="btn-unfollow">✓ Following</button>
                        </form>
                    }
                    else
                    {
                        <form method="post" asp-page-handler="Follow">
                            <input type="hidden" name="userId" value="@Model.ProfileUser.Id" />
                            <button type="submit" class="btn-follow">+ Follow</button>
                        </form>
                    }
                </div>
            }
            else
            {
                <a class="btn-sb-ghost" asp-page="/Dashboard/Index">Go to Dashboard</a>
            }
        </div>
    </div>
</div>

<!-- Tabs -->
<div class="profile-tabs">
    <button class="tab-btn active" onclick="switchTab('notes', this)">
        📝 Notes <span class="tab-count">@Model.UserNotes.Count</span>
    </button>
    <button class="tab-btn" onclick="switchTab('blogs', this)">
        ✍️ Blogs <span class="tab-count">@Model.UserBlogs.Count</span>
    </button>
    <button class="tab-btn" onclick="switchTab('followers', this)">
        👥 Followers <span class="tab-count">@Model.Followers.Count</span>
    </button>
</div>

<!-- Notes Tab -->
<div class="tab-panel active" id="tab-notes">
    <div class="profile-grid">
        @if (!Model.UserNotes.Any())
        {
            <div class="profile-empty">
                <div class="profile-empty-icon">📝</div>
                <h3>No notes yet</h3>
                <p>@Model.ProfileUser.FirstName hasn't shared any notes yet.</p>
            </div>
        }
        else
        {
            @foreach (var note in Model.UserNotes)
            {
                <a class="profile-note-card" asp-page="/Notes/Details" asp-route-id="@note.Id">
                    <span class="card-subject">@note.Subject</span>
                    <h3 class="card-title">@note.Topic</h3>
                    <p class="card-excerpt">@note.BriefExplanation</p>
                    <div class="card-footer">
                        <span>@note.DateOfCreation.ToString("MMM dd, yyyy")</span>
                        <span>❤️ @note.Likes</span>
                    </div>
                </a>
            }
        }
    </div>
</div>

<!-- Blogs Tab -->
<div class="tab-panel" id="tab-blogs">
    @if (!Model.UserBlogs.Any())
    {
        <div class="profile-empty">
            <div class="profile-empty-icon">✍️</div>
            <h3>No blogs yet</h3>
            <p>@Model.ProfileUser.FirstName hasn't published any blogs yet.</p>
        </div>
    }
    else
    {
        @foreach (var blog in Model.UserBlogs)
        {
            <a class="profile-blog-card" asp-page="/Blogs/Details" asp-route-id="@blog.Id">
                <div class="profile-blog-content">
                    <h3 class="profile-blog-title">@blog.Title</h3>
                    <p class="profile-blog-summary">@blog.Summary</p>
                    <div class="profile-blog-meta">
                        <span>📅 @blog.PublishedAt?.ToString("MMM dd, yyyy")</span>
                        <span>❤️ @blog.Likes</span>
                        <span>👁️ @blog.Views views</span>
                    </div>
                </div>
            </a>
        }
    }
</div>

<!-- Followers Tab -->
<div class="tab-panel" id="tab-followers">
    <div class="followers-grid">
        @if (!Model.Followers.Any())
        {
            <div class="profile-empty">
                <div class="profile-empty-icon">👥</div>
                <h3>No followers yet</h3>
                <p>@Model.ProfileUser.FirstName doesn't have any followers yet.</p>
            </div>
        }
        else
        {
            @foreach (var follower in Model.Followers)
            {
                <a class="follower-card" asp-page="/Profile/Index" asp-route-userId="@follower.Id">
                    <div class="follower-avatar">
                        @(follower.FirstName?.Substring(0, 1).ToUpper())@(follower.LastName?.Substring(0, 1).ToUpper())
                    </div>
                    <div class="follower-name">@follower.FirstName @follower.LastName</div>
                    <div class="follower-nationality">@follower.Nationality</div>
                </a>
            }
        }
    </div>
</div>

@section Scripts {
    <script>
        function switchTab(name, btn) {
            document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
            document.getElementById('tab-' + name).classList.add('active');
            btn.classList.add('active');
        }
    </script>
}

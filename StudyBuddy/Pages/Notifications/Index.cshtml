@page
@model StudyBuddy.Pages.Notifications.IndexModel
@{
    ViewData["Title"] = "Notifications";
}

<style>
    .notif-page {
        max-width: 680px;
        margin: 0 auto;
    }

    .notif-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 1.5rem;
    }

    .notif-title {
        font-family: var(--font-heading);
        font-size: 1.6rem;
        color: var(--navy);
        margin: 0;
    }

    .notif-list {
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .notif-item {
        display: flex;
        align-items: flex-start;
        gap: 1rem;
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1rem 1.25rem;
        box-shadow: var(--card-shadow);
        text-decoration: none;
        color: inherit;
        transition: all 0.2s ease;
        animation: fadeInUp 0.3s ease both;
        position: relative;
    }

        .notif-item:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 16px rgba(27,42,74,0.12);
            border-color: var(--navy);
            color: inherit;
            text-decoration: none;
        }

        .notif-item.unread {
            border-left: 3px solid var(--amber);
            background: #FFFDF7;
        }

    .notif-avatar {
        width: 40px;
        height: 40px;
        border-radius: 50%;
        background: var(--navy);
        color: var(--white);
        display: flex;
        align-items: center;
        justify-content: center;
        font-weight: 600;
        font-size: 0.85rem;
        flex-shrink: 0;
    }

    .notif-body {
        flex: 1;
    }

    .notif-message {
        font-size: 0.9rem;
        color: var(--text-dark);
        margin: 0 0 0.25rem;
        font-weight: 500;
    }

    .notif-time {
        font-size: 0.78rem;
        color: var(--text-muted);
    }

    .notif-icon {
        font-size: 1.1rem;
        flex-shrink: 0;
        margin-top: 2px;
    }

    .notif-empty {
        text-align: center;
        padding: 4rem 2rem;
        color: var(--text-muted);
    }

    .notif-empty-icon {
        font-size: 3rem;
        margin-bottom: 1rem;
    }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(12px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    .notif-item:nth-child(1) {
        animation-delay: 0.00s;
    }

    .notif-item:nth-child(2) {
        animation-delay: 0.04s;
    }

    .notif-item:nth-child(3) {
        animation-delay: 0.08s;
    }

    .notif-item:nth-child(4) {
        animation-delay: 0.12s;
    }

    .notif-item:nth-child(5) {
        animation-delay: 0.16s;
    }

    .notif-item:nth-child(6) {
        animation-delay: 0.20s;
    }
</style>

<div class="notif-page">
    <div class="notif-header">
        <h1 class="notif-title">🔔 Notifications</h1>
        <span style="font-size:0.85rem; color:var(--text-muted);">
            @Model.Notifications.Count notification@(Model.Notifications.Count != 1 ? "s" : "")
        </span>
    </div>

    @if (!Model.Notifications.Any())
    {
        <div class="notif-empty">
            <div class="notif-empty-icon">🔕</div>
            <p>You're all caught up! No notifications yet.</p>
        </div>
    }
    else
    {
        <div class="notif-list">
            @foreach (var n in Model.Notifications)
            {
                var icon = n.Type switch
                {
                    StudyBuddy.Models.NotificationType.NoteLiked => "❤️",
                    StudyBuddy.Models.NotificationType.BlogLiked => "❤️",
                    StudyBuddy.Models.NotificationType.CommentLiked => "👍",
                    StudyBuddy.Models.NotificationType.NewComment => "💬",
                    StudyBuddy.Models.NotificationType.NewFollower => "👤",
                    _ => "🔔"
                };

                var href = n.Type switch
                {
                    StudyBuddy.Models.NotificationType.NoteLiked when n.NoteId != null => $"/Notes/Details/{n.NoteId}",
                    StudyBuddy.Models.NotificationType.BlogLiked when n.BlogId != null => $"/Blogs/Details/{n.BlogId}",
                    StudyBuddy.Models.NotificationType.NewComment when n.BlogId != null => $"/Blogs/Details/{n.BlogId}",
                    StudyBuddy.Models.NotificationType.NewFollower => $"/Profile/Index?userId={n.ActorId}",
                    _ => "#"
                };

                var actorName = n.Actor != null ? $"{n.Actor.FirstName} {n.Actor.LastName}" : "Someone";
                var message = n.Type switch
                {
                    StudyBuddy.Models.NotificationType.NoteLiked => $"{actorName} liked your note",
                    StudyBuddy.Models.NotificationType.BlogLiked => $"{actorName} liked your blog",
                    StudyBuddy.Models.NotificationType.CommentLiked => $"{actorName} liked your comment",
                    StudyBuddy.Models.NotificationType.NewComment => $"{actorName} commented on your blog",
                    StudyBuddy.Models.NotificationType.NewFollower => $"{actorName} started following you",
                    _ => $"{actorName} interacted with your content"
                };

                var initials = n.Actor != null
                    ? $"{n.Actor.FirstName[0]}{n.Actor.LastName[0]}".ToUpper()
                    : "?";

                var timeAgo = GetTimeAgo(n.CreatedAt);

                <a href="@href" class="notif-item @(!n.IsRead ? "unread" : "")">
                    <div class="notif-avatar">@initials</div>
                    <div class="notif-body">
                        <p class="notif-message">@message</p>
                        <span class="notif-time">@timeAgo</span>
                    </div>
                    <div class="notif-icon">@icon</div>
                </a>
            }
        </div>
    }
</div>

@functions {
    string GetTimeAgo(DateTime utcTime)
    {
        var diff = DateTime.UtcNow - utcTime;
        if (diff.TotalSeconds < 60) return "Just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";
        return utcTime.ToLocalTime().ToString("MMM d");
    }
}

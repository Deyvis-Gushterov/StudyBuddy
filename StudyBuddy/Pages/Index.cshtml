@page
@model IndexModel
@{
    ViewData["Title"] = "Home";
}

<style>
    .sb-main { padding: 0 !important; }
    .sb-container { max-width: 100% !important; padding: 0 !important; }

    
    .hero {
        background: var(--white);
        padding: 6rem 1.5rem 5rem;
        text-align: center;
        border-bottom: 1px solid var(--border);
        position: relative;
        overflow: hidden;
    }

    .hero::before {
        content: '';
        position: absolute;
        top: -80px;
        right: -80px;
        width: 400px;
        height: 400px;
        background: radial-gradient(circle, rgba(212,137,10,0.07) 0%, transparent 70%);
        pointer-events: none;
    }

    .hero::after {
        content: '';
        position: absolute;
        bottom: -60px;
        left: -60px;
        width: 300px;
        height: 300px;
        background: radial-gradient(circle, rgba(27,42,74,0.06) 0%, transparent 70%);
        pointer-events: none;
    }

    .hero-inner {
        max-width: 720px;
        margin: 0 auto;
        position: relative;
        z-index: 1;
    }

    .hero-pill {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        background: #FEF3C7;
        color: #92400E;
        border: 1px solid #FCD34D;
        font-size: 0.78rem;
        font-weight: 600;
        padding: 4px 14px;
        border-radius: 20px;
        margin-bottom: 1.5rem;
        letter-spacing: 0.3px;
    }

    .hero-pill-dot {
        width: 6px;
        height: 6px;
        background: var(--amber);
        border-radius: 50%;
    }

    .hero h1 {
        font-size: clamp(2.2rem, 5vw, 3.5rem);
        font-weight: 700;
        line-height: 1.15;
        color: var(--navy);
        margin-bottom: 1.25rem;
    }

    .hero h1 em {
        font-style: italic;
        color: var(--amber);
    }

    .hero p {
        font-size: 1.1rem;
        color: var(--text-muted);
        max-width: 520px;
        margin: 0 auto 2.5rem;
        line-height: 1.7;
    }

    .hero-cta {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .btn-hero-primary {
        font-family: var(--font-body);
        font-size: 1rem;
        font-weight: 600;
        color: var(--white);
        background: var(--navy);
        border: none;
        padding: 0.75rem 2rem;
        border-radius: 10px;
        text-decoration: none;
        transition: all 0.2s ease;
        display: inline-flex;
        align-items: center;
        gap: 8px;
    }

    .btn-hero-primary:hover {
        background: var(--navy-light);
        color: var(--white);
        text-decoration: none;
        transform: translateY(-1px);
        box-shadow: 0 6px 20px rgba(27,42,74,0.2);
    }

    .btn-hero-ghost {
        font-family: var(--font-body);
        font-size: 1rem;
        font-weight: 500;
        color: var(--navy);
        background: transparent;
        border: 1.5px solid var(--border);
        padding: 0.75rem 2rem;
        border-radius: 10px;
        text-decoration: none;
        transition: all 0.2s ease;
    }

    .btn-hero-ghost:hover {
        border-color: var(--navy);
        color: var(--navy);
        text-decoration: none;
        transform: translateY(-1px);
    }

    .hero-stats {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 2.5rem;
        margin-top: 3.5rem;
        padding-top: 2rem;
        border-top: 1px solid var(--border);
        flex-wrap: wrap;
    }

    .hero-stat-num {
        font-family: var(--font-heading);
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--navy);
    }

    .hero-stat-label {
        font-size: 0.8rem;
        color: var(--text-muted);
        margin-top: 2px;
    }

    /* ── Features ── */
    .features {
        padding: 5rem 1.5rem;
        background: var(--cream);
    }

    .features-inner { max-width: 1100px; margin: 0 auto; }

    .section-label {
        font-size: 0.78rem;
        font-weight: 600;
        color: var(--amber);
        letter-spacing: 1px;
        text-transform: uppercase;
        margin-bottom: 0.75rem;
    }

    .section-title {
        font-family: var(--font-heading);
        font-size: clamp(1.6rem, 3vw, 2.25rem);
        font-weight: 700;
        color: var(--navy);
        margin-bottom: 0.75rem;
    }

    .section-sub {
        font-size: 1rem;
        color: var(--text-muted);
        max-width: 500px;
        line-height: 1.7;
    }

    .features-header {
        margin-bottom: 3rem;
    }

    .features-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(280px, 1fr));
        gap: 1.5rem;
    }

    .feature-card {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 2rem;
        transition: all 0.2s ease;
        position: relative;
        overflow: hidden;
    }

    .feature-card:hover {
        transform: translateY(-3px);
        box-shadow: 0 8px 30px rgba(27,42,74,0.1);
        border-color: transparent;
    }

    .feature-icon {
        width: 48px;
        height: 48px;
        border-radius: 12px;
        display: flex;
        align-items: center;
        justify-content: center;
        margin-bottom: 1.25rem;
        font-size: 1.4rem;
    }

    .feature-icon-navy { background: #EEF0F8; }
    .feature-icon-amber { background: #FEF3C7; }
    .feature-icon-teal { background: #E0F2F1; }

    .feature-card h3 {
        font-size: 1.1rem;
        font-weight: 600;
        color: var(--navy);
        margin-bottom: 0.6rem;
    }

    .feature-card p {
        font-size: 0.9rem;
        color: var(--text-muted);
        line-height: 1.65;
        margin: 0;
    }

    .feature-tag {
        display: inline-block;
        font-size: 0.7rem;
        font-weight: 600;
        padding: 2px 8px;
        border-radius: 20px;
        margin-top: 1rem;
    }

    .feature-tag-new { background: #D1FAE5; color: #065F46; }
    .feature-tag-soon { background: #FEF3C7; color: #92400E; }

    /* ── How it works ── */
    .how {
        padding: 5rem 1.5rem;
        background: var(--white);
        border-top: 1px solid var(--border);
    }

    .how-inner {
        max-width: 1100px;
        margin: 0 auto;
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 4rem;
        align-items: center;
    }

    .how-steps { display: flex; flex-direction: column; gap: 1.75rem; }

    .how-step {
        display: flex;
        gap: 1.25rem;
        align-items: flex-start;
    }

    .how-step-num {
        width: 36px;
        height: 36px;
        min-width: 36px;
        background: var(--navy);
        color: var(--amber);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: var(--font-heading);
        font-size: 0.95rem;
        font-weight: 700;
    }

    .how-step-content h4 {
        font-size: 1rem;
        font-weight: 600;
        color: var(--navy);
        margin-bottom: 0.3rem;
    }

    .how-step-content p {
        font-size: 0.875rem;
        color: var(--text-muted);
        margin: 0;
        line-height: 1.6;
    }

    .how-visual {
        background: var(--cream);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 2rem;
        min-height: 320px;
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .mock-note {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 1rem 1.25rem;
    }

    .mock-note-header {
        display: flex;
        align-items: center;
        gap: 8px;
        margin-bottom: 0.5rem;
    }

    .mock-dot {
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: var(--amber);
    }

    .mock-note-title {
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--navy);
    }

    .mock-line {
        height: 8px;
        background: var(--border);
        border-radius: 4px;
        margin-bottom: 6px;
    }

    .mock-line.short { width: 60%; }
    .mock-line.medium { width: 80%; }

    .mock-tag-row { display: flex; gap: 6px; margin-top: 0.75rem; }

    .mock-tag {
        font-size: 0.68rem;
        padding: 2px 8px;
        background: var(--cream);
        border: 1px solid var(--border);
        border-radius: 20px;
        color: var(--text-muted);
    }

    /* ── CTA Section ── */
    .cta-section {
        padding: 5rem 1.5rem;
        background: var(--navy);
        text-align: center;
    }

    .cta-inner { max-width: 600px; margin: 0 auto; }

    .cta-section h2 {
        font-family: var(--font-heading);
        font-size: clamp(1.8rem, 4vw, 2.5rem);
        font-weight: 700;
        color: var(--white);
        margin-bottom: 1rem;
    }

    .cta-section h2 em {
        color: var(--amber);
        font-style: italic;
    }

    .cta-section p {
        color: rgba(255,255,255,0.7);
        font-size: 1rem;
        margin-bottom: 2rem;
        line-height: 1.7;
    }

    .btn-cta {
        font-family: var(--font-body);
        font-size: 1rem;
        font-weight: 600;
        color: var(--navy);
        background: var(--amber);
        border: none;
        padding: 0.85rem 2.5rem;
        border-radius: 10px;
        text-decoration: none;
        transition: all 0.2s ease;
        display: inline-block;
    }

    .btn-cta:hover {
        background: #e09a0d;
        color: var(--navy);
        text-decoration: none;
        transform: translateY(-2px);
        box-shadow: 0 8px 24px rgba(0,0,0,0.2);
    }

    @@media (max-width: 768px) {
        .how-inner { grid-template-columns: 1fr; gap: 2rem; }
        .how-visual { display: none; }
        .hero { padding: 4rem 1.5rem 3rem; }
        .features, .how, .cta-section { padding: 3.5rem 1.5rem; }
    }
</style>


<section class="hero">
    <div class="hero-inner">
        <div class="hero-pill">
            <span class="hero-pill-dot"></span>
            Now with AI-powered study assistant
        </div>
        <h1>The smarter way to<br><em>study together</em></h1>
        <p>Share notes, write blogs, and learn from your peers. StudyBuddy is the academic social platform built for students who take learning seriously.</p>
        <div class="hero-cta">
            <a class="btn-hero-primary" asp-area="Identity" asp-page="/Account/Register">
                Start for free →
            </a>
            <a class="btn-hero-ghost" asp-area="Identity" asp-page="/Account/Login">
                Sign in
            </a>
        </div>
        <div class="hero-stats">
            <div>
                <div class="hero-stat-num">10k+</div>
                <div class="hero-stat-label">Notes shared</div>
            </div>
            <div style="width:1px; height:36px; background:var(--border);"></div>
            <div>
                <div class="hero-stat-num">2.4k</div>
                <div class="hero-stat-label">Students</div>
            </div>
            <div style="width:1px; height:36px; background:var(--border);"></div>
            <div>
                <div class="hero-stat-num">500+</div>
                <div class="hero-stat-label">Blogs published</div>
            </div>
        </div>
    </div>
</section>


<section class="features" id="features">
    <div class="features-inner">
        <div class="features-header">
            <div class="section-label">Features</div>
            <h2 class="section-title">Everything you need to learn better</h2>
            <p class="section-sub">From sharing handwritten notes to publishing study blogs — StudyBuddy has all the tools for collaborative learning.</p>
        </div>
        <div class="features-grid">
            <div class="feature-card">
                <div class="feature-icon feature-icon-navy">📝</div>
                <h3>Share Notes</h3>
                <p>Upload and organize your notes by subject. Save other students' notes to your personal library and study smarter.</p>
                <span class="feature-tag feature-tag-new">Available</span>
            </div>
            <div class="feature-card">
                <div class="feature-icon feature-icon-amber">✍️</div>
                <h3>Write Blogs</h3>
                <p>Publish study guides, deep dives, and academic articles. Build your reputation as a top contributor in your field.</p>
                <span class="feature-tag feature-tag-new">Available</span>
            </div>
            <div class="feature-card">
                <div class="feature-icon feature-icon-teal">🤖</div>
                <h3>AI Study Assistant</h3>
                <p>Ask questions about any note, get instant summaries, and receive writing suggestions for your blogs — powered by AI.</p>
                <span class="feature-tag feature-tag-soon">Coming soon</span>
            </div>
            <div class="feature-card">
                <div class="feature-icon feature-icon-navy">👥</div>
                <h3>Follow & Connect</h3>
                <p>Follow top students in your subject area. Build a feed of notes and blogs that actually matters to your studies.</p>
                <span class="feature-tag feature-tag-new">Available</span>
            </div>
            <div class="feature-card">
                <div class="feature-icon feature-icon-amber">💬</div>
                <h3>Discuss & Comment</h3>
                <p>Ask questions on blogs, leave feedback on notes, and engage in academic discussions with fellow students.</p>
                <span class="feature-tag feature-tag-new">Available</span>
            </div>
            <div class="feature-card">
                <div class="feature-icon feature-icon-teal">⭐</div>
                <h3>Like & Save</h3>
                <p>Bookmark the best notes and blogs. Like great content and help surface the most valuable study materials for everyone.</p>
                <span class="feature-tag feature-tag-new">Available</span>
            </div>
        </div>
    </div>
</section>


<section class="how" id="about">
    <div class="how-inner">
        <div>
            <div class="section-label">How it works</div>
            <h2 class="section-title">Up and running in minutes</h2>
            <div class="how-steps">
                <div class="how-step">
                    <div class="how-step-num">1</div>
                    <div class="how-step-content">
                        <h4>Create your account</h4>
                        <p>Sign up for free. No credit card needed. Just your name, email, and you're in.</p>
                    </div>
                </div>
                <div class="how-step">
                    <div class="how-step-num">2</div>
                    <div class="how-step-content">
                        <h4>Share your first note</h4>
                        <p>Upload notes from any subject. Add tags, a brief explanation, and publish to the community.</p>
                    </div>
                </div>
                <div class="how-step">
                    <div class="how-step-num">3</div>
                    <div class="how-step-content">
                        <h4>Discover and save</h4>
                        <p>Browse notes and blogs from other students. Save the best ones to your personal library.</p>
                    </div>
                </div>
                <div class="how-step">
                    <div class="how-step-num">4</div>
                    <div class="how-step-content">
                        <h4>Use the AI assistant</h4>
                        <p>Ask questions about any note. Get summaries, explanations, and writing help instantly.</p>
                    </div>
                </div>
            </div>
        </div>

       
        <div class="how-visual">
            <div class="mock-note">
                <div class="mock-note-header">
                    <div class="mock-dot"></div>
                    <div class="mock-note-title">Calculus — Integration by Parts</div>
                </div>
                <div class="mock-line medium"></div>
                <div class="mock-line short"></div>
                <div class="mock-line medium"></div>
                <div class="mock-tag-row">
                    <span class="mock-tag">Math</span>
                    <span class="mock-tag">Calculus</span>
                    <span class="mock-tag">Year 2</span>
                </div>
            </div>
            <div class="mock-note">
                <div class="mock-note-header">
                    <div class="mock-dot" style="background:#1B2A4A"></div>
                    <div class="mock-note-title">Organic Chemistry — Reactions</div>
                </div>
                <div class="mock-line medium"></div>
                <div class="mock-line short"></div>
                <div class="mock-tag-row">
                    <span class="mock-tag">Chemistry</span>
                    <span class="mock-tag">Organic</span>
                </div>
            </div>
            <div class="mock-note" style="border-color: var(--amber); border-width: 1.5px;">
                <div class="mock-note-header">
                    <div class="mock-dot" style="background:#10B981"></div>
                    <div class="mock-note-title">🤖 AI Summary ready</div>
                </div>
                <div class="mock-line medium" style="background:#D1FAE5;"></div>
                <div class="mock-line short" style="background:#D1FAE5;"></div>
            </div>
        </div>
    </div>
</section>


<section class="cta-section">
    <div class="cta-inner">
        <h2>Ready to study <em>smarter?</em></h2>
        <p>Join thousands of students already sharing notes and learning together on StudyBuddy.</p>
        <a class="btn-cta" asp-area="Identity" asp-page="/Account/Register">
            Create your free account
        </a>
    </div>
</section>

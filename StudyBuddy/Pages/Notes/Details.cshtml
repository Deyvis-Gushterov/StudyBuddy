@page "{id:int}"
@model StudyBuddy.Pages.NotePages.DetailsModel
@{
    ViewData["Title"] = Model.Note?.Topic ?? "Note Details";
}

<style>
    .details-layout {
        display: grid;
        grid-template-columns: 1fr 300px;
        gap: 2rem;
        align-items: flex-start;
    }

    .note-content-card {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 14px;
        overflow: hidden;
        box-shadow: var(--card-shadow);
    }

    .note-content-header {
        padding: 2rem 2rem 1.5rem;
        border-bottom: 1px solid var(--border);
    }

    .note-subject-badge {
        display: inline-block;
        font-size: 0.72rem;
        font-weight: 600;
        color: var(--amber);
        background: #FEF3C7;
        border: 1px solid #FCD34D;
        padding: 3px 12px;
        border-radius: 20px;
        margin-bottom: 1rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .note-content-header h1 {
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--navy);
        margin-bottom: 1rem;
        line-height: 1.3;
    }

    .note-meta {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        flex-wrap: wrap;
    }

    .note-meta-author {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .note-meta-avatar {
        width: 32px;
        height: 32px;
        background: var(--navy);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 600;
        color: var(--amber);
    }

    .note-meta-author-info strong {
        font-size: 0.88rem;
        font-weight: 600;
        color: var(--navy);
        display: block;
    }

    .note-meta-author-info span {
        font-size: 0.78rem;
        color: var(--text-muted);
    }

    .note-meta-divider {
        width: 1px;
        height: 28px;
        background: var(--border);
    }

    .note-meta-stat {
        font-size: 0.82rem;
        color: var(--text-muted);
    }

    .note-brief {
        padding: 1.5rem 2rem;
        background: var(--cream);
        border-bottom: 1px solid var(--border);
    }

    .note-brief-label {
        font-size: 0.72rem;
        font-weight: 600;
        color: var(--amber);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 0.4rem;
    }

    .note-brief p {
        font-size: 0.95rem;
        color: var(--text-muted);
        margin: 0;
        line-height: 1.65;
        font-style: italic;
    }

    .note-content-body {
        padding: 2rem;
    }

        .note-content-body p {
            font-size: 0.95rem;
            line-height: 1.8;
            color: var(--text-dark);
            white-space: pre-wrap;
        }

    .note-actions-bar {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1.25rem 2rem;
        border-top: 1px solid var(--border);
        background: var(--cream);
        flex-wrap: wrap;
    }

    .action-btn {
        display: flex;
        align-items: center;
        gap: 6px;
        font-family: var(--font-body);
        font-size: 0.85rem;
        font-weight: 500;
        padding: 0.45rem 1rem;
        border-radius: 8px;
        border: 1.5px solid var(--border);
        background: var(--white);
        color: var(--text-muted);
        cursor: pointer;
        transition: all 0.15s;
        text-decoration: none;
    }

        .action-btn:hover {
            border-color: var(--navy);
            color: var(--navy);
            text-decoration: none;
        }

        .action-btn svg {
            width: 15px;
            height: 15px;
            stroke: currentColor;
            fill: none;
        }

    .action-btn-danger {
        border-color: #FCA5A5;
        color: #EF4444;
        margin-left: auto;
    }

        .action-btn-danger:hover {
            border-color: #EF4444;
            background: #FEE2E2;
            color: #EF4444;
        }

    /* Sidebar */
    .details-sidebar {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        position: sticky;
        top: 80px;
    }

    .sidebar-card {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1.25rem 1.5rem;
    }

        .sidebar-card h4 {
            font-size: 0.88rem;
            font-weight: 600;
            color: var(--navy);
            margin-bottom: 1rem;
            padding-bottom: 0.6rem;
            border-bottom: 1px solid var(--border);
        }

    .author-profile {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 0.5rem;
    }

    .author-avatar-lg {
        width: 56px;
        height: 56px;
        background: var(--navy);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        font-weight: 700;
        color: var(--amber);
    }

    .author-name {
        font-weight: 600;
        color: var(--navy);
        font-size: 0.95rem;
    }

    .author-nationality {
        font-size: 0.8rem;
        color: var(--text-muted);
    }

    /* ── AI Section ── */
    .ai-section {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 14px;
        overflow: hidden;
        box-shadow: var(--card-shadow);
        margin-top: 1.5rem;
    }

    .ai-section-header {
        padding: 1.25rem 1.75rem;
        border-bottom: 1px solid var(--border);
        background: linear-gradient(135deg, #1B2A4A 0%, #243659 100%);
        display: flex;
        align-items: center;
        justify-content: space-between;
    }

        .ai-section-header h3 {
            font-size: 1rem;
            font-weight: 600;
            color: var(--white);
            margin: 0;
            display: flex;
            align-items: center;
            gap: 8px;
        }

    .ai-badge {
        font-size: 0.68rem;
        font-weight: 600;
        background: var(--amber);
        color: var(--navy);
        padding: 2px 8px;
        border-radius: 20px;
    }

    .ai-tabs {
        display: flex;
        border-bottom: 1px solid var(--border);
    }

    .ai-tab-btn {
        flex: 1;
        font-family: var(--font-body);
        font-size: 0.85rem;
        font-weight: 500;
        color: var(--text-muted);
        background: var(--cream);
        border: none;
        padding: 0.75rem;
        cursor: pointer;
        border-bottom: 2px solid transparent;
        transition: all 0.15s;
    }

        .ai-tab-btn:hover {
            color: var(--navy);
            background: var(--white);
        }

        .ai-tab-btn.active {
            color: var(--navy);
            background: var(--white);
            border-bottom-color: var(--navy);
            font-weight: 600;
        }

    .ai-tab-panel {
        display: none;
        padding: 1.5rem 1.75rem;
    }

        .ai-tab-panel.active {
            display: block;
        }

    /* Chat */
    .ai-chat-messages {
        min-height: 80px;
        max-height: 320px;
        overflow-y: auto;
        margin-bottom: 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.75rem;
    }

    .ai-message {
        padding: 0.85rem 1rem;
        border-radius: 10px;
        font-size: 0.875rem;
        line-height: 1.65;
    }

    .ai-message-user {
        background: var(--navy);
        color: var(--white);
        align-self: flex-end;
        max-width: 85%;
        border-radius: 10px 10px 2px 10px;
    }

    .ai-message-ai {
        background: var(--cream);
        color: var(--text-dark);
        border: 1px solid var(--border);
        align-self: flex-start;
        max-width: 95%;
        border-radius: 10px 10px 10px 2px;
    }

    .ai-message-ai-header {
        font-size: 0.72rem;
        font-weight: 600;
        color: var(--amber);
        margin-bottom: 0.4rem;
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .ai-input-row {
        display: flex;
        gap: 0.5rem;
        align-items: flex-end;
    }

        .ai-input-row textarea {
            flex: 1;
            min-height: 44px;
            max-height: 100px;
            resize: none;
        }

    .ai-submit-btn {
        font-family: var(--font-body);
        font-size: 0.85rem;
        font-weight: 600;
        color: var(--white);
        background: var(--navy);
        border: none;
        padding: 0.6rem 1.1rem;
        border-radius: 8px;
        cursor: pointer;
        white-space: nowrap;
        align-self: flex-end;
    }

    /* Summary */
    .ai-summary-box {
        background: var(--cream);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 1.1rem 1.25rem;
        font-size: 0.9rem;
        line-height: 1.75;
        color: var(--text-dark);
        margin-bottom: 1rem;
    }

    .ai-empty {
        text-align: center;
        padding: 1.5rem;
        color: var(--text-muted);
        font-size: 0.875rem;
    }

    .ai-empty-icon {
        font-size: 1.75rem;
        margin-bottom: 0.5rem;
    }

    /* Loading spinner */
    .ai-loading {
        display: flex;
        align-items: center;
        gap: 8px;
        color: var(--text-muted);
        font-size: 0.85rem;
        padding: 0.75rem 0;
    }

    .ai-spinner {
        width: 16px;
        height: 16px;
        border: 2px solid var(--border);
        border-top-color: var(--navy);
        border-radius: 50%;
        animation: spin 0.7s linear infinite;
    }

    @@keyframes spin {
        to {
            transform: rotate(360deg);
        }
    }

    /* Comments */
    .comments-section {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1.5rem 2rem;
        box-shadow: var(--card-shadow);
        margin-top: 1.5rem;
    }

        .comments-section h3 {
            font-size: 1.1rem;
            color: var(--navy);
            margin-bottom: 1.5rem;
            padding-bottom: 0.75rem;
            border-bottom: 1px solid var(--border);
        }

    .comment-input-row {
        display: flex;
        gap: 0.75rem;
        align-items: flex-start;
        margin-bottom: 1.5rem;
    }

    .comment-avatar {
        width: 32px;
        height: 32px;
        min-width: 32px;
        background: var(--navy);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
        font-weight: 600;
        color: var(--amber);
    }

    .comment-input-wrap {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .empty-comments {
        text-align: center;
        padding: 2rem;
        color: var(--text-muted);
        font-size: 0.9rem;
    }

    @@media (max-width: 768px) {
        .details-layout {
            grid-template-columns: 1fr;
        }

        .note-content-header {
            padding: 1.5rem;
        }

        .note-content-body {
            padding: 1.5rem;
        }

        .note-actions-bar {
            padding: 1rem 1.5rem;
            flex-wrap: wrap;
        }

        .details-sidebar {
            position: static;
        }
    }

    .ai-markdown h1, .ai-markdown h2, .ai-markdown h3 {
        font-family: var(--font-heading);
        color: var(--navy);
        margin: 0.75rem 0 0.4rem;
        font-size: 1rem;
    }

    .ai-markdown p {
        margin: 0 0 0.6rem;
        line-height: 1.7;
    }

    .ai-markdown ul, .ai-markdown ol {
        padding-left: 1.25rem;
        margin: 0 0 0.6rem;
    }

    .ai-markdown li {
        margin-bottom: 0.3rem;
        line-height: 1.6;
    }

    .ai-markdown strong {
        color: var(--navy);
        font-weight: 600;
    }

    .ai-markdown code {
        background: var(--cream);
        border: 1px solid var(--border);
        border-radius: 4px;
        padding: 1px 6px;
        font-size: 0.85em;
        font-family: monospace;
    }

    .ai-markdown blockquote {
        border-left: 3px solid var(--amber);
        padding-left: 1rem;
        color: var(--text-muted);
        margin: 0.5rem 0;
    }

    /* ── Entrance Animations ── */
    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(18px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    @@keyframes slideInRight {
        from {
            opacity: 0;
            transform: translateX(16px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @@keyframes shimmer {
        0% {
            background-position: -400px 0;
        }

        100% {
            background-position: 400px 0;
        }
    }

    @@keyframes typingDot {
        0%, 80%, 100% {
            transform: scale(0.6);
            opacity: 0.4;
        }

        40% {
            transform: scale(1);
            opacity: 1;
        }
    }

    @@keyframes popIn {
        0% {
            transform: scale(0.92);
            opacity: 0;
        }

        60% {
            transform: scale(1.03);
        }

        100% {
            transform: scale(1);
            opacity: 1;
        }
    }

    .note-content-card {
        animation: fadeInUp 0.45s ease both;
    }

    .ai-section {
        animation: fadeInUp 0.45s 0.1s ease both;
    }

    .comments-section {
        animation: fadeInUp 0.45s 0.2s ease both;
    }

    .details-sidebar .sidebar-card:nth-child(1) {
        animation: slideInRight 0.45s 0.05s ease both;
    }

    .details-sidebar .sidebar-card:nth-child(2) {
        animation: slideInRight 0.45s 0.15s ease both;
    }

    /* Action button micro-interactions */
    .action-btn {
        transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

        .action-btn:hover {
            transform: translateY(-1px);
            box-shadow: 0 4px 12px rgba(27,42,74,0.12);
        }

        .action-btn:active {
            transform: scale(0.96);
        }

    /* AI submit button */
    .ai-submit-btn {
        transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
    }

        .ai-submit-btn:hover:not(:disabled) {
            transform: translateY(-1px);
            box-shadow: 0 4px 14px rgba(27,42,74,0.25);
        }

        .ai-submit-btn:active:not(:disabled) {
            transform: scale(0.97);
        }

        .ai-submit-btn:disabled {
            opacity: 0.65;
            cursor: not-allowed;
        }

    /* AI message pop-in */
    .ai-message {
        animation: popIn 0.35s ease both;
    }

    /* Typing indicator */
    .ai-typing {
        display: flex;
        align-items: center;
        gap: 6px;
        padding: 0.75rem 1rem;
        background: var(--cream);
        border: 1px solid var(--border);
        border-radius: 10px 10px 10px 2px;
        align-self: flex-start;
        width: fit-content;
    }

    .ai-typing-dot {
        width: 7px;
        height: 7px;
        background: var(--navy);
        border-radius: 50%;
        animation: typingDot 1.2s ease-in-out infinite;
    }

        .ai-typing-dot:nth-child(2) {
            animation-delay: 0.2s;
        }

        .ai-typing-dot:nth-child(3) {
            animation-delay: 0.4s;
        }

    /* Shimmer skeleton for summary loading */
    .ai-skeleton {
        height: 14px;
        border-radius: 6px;
        margin-bottom: 10px;
        background: linear-gradient(90deg, var(--border) 25%, #f0eee9 50%, var(--border) 75%);
        background-size: 800px 100%;
        animation: shimmer 1.4s infinite linear;
    }

        .ai-skeleton:last-child {
            width: 65%;
        }

    /* Like button liked state */
    .action-btn.liked {
        border-color: #FCA5A5;
        color: #EF4444;
    }

        .action-btn.liked:hover {
            background: #FEE2E2;
        }

    /* Tab transition */
    .ai-tab-panel {
        transition: opacity 0.2s ease;
    }

        .ai-tab-panel:not(.active) {
            opacity: 0;
            pointer-events: none;
        }

        .ai-tab-panel.active {
            opacity: 1;
        }
</style>

@if (Model.Note == null)
{
    <div class="sb-alert sb-alert-danger">Note not found.</div>
    return;
}

<div style="margin-bottom: 1.5rem;">
    <a class="btn-sb-ghost" asp-page="/Notes/Index">← Back to Notes</a>
</div>

<div class="details-layout">
    <div>
        <!-- Main Note Card -->
        <div class="note-content-card">
            <div class="note-content-header">
                <span class="note-subject-badge">@Model.Note.Subject</span>
                <h1>@Model.Note.Topic</h1>
                <div class="note-meta">
                    <div class="note-meta-author">
                        <div class="note-meta-avatar">
                            @(Model.Note.Creator?.FirstName?.Substring(0, 1).ToUpper())@(Model.Note.Creator?.LastName?.Substring(0, 1).ToUpper())
                        </div>
                        <div class="note-meta-author-info">
                            <strong>@Model.Note.Creator?.FirstName @Model.Note.Creator?.LastName</strong>
                            <span>@Model.Note.DateOfCreation.ToString("MMMM dd, yyyy")</span>
                        </div>
                    </div>
                    <div class="note-meta-divider"></div>
                    <span class="note-meta-stat">❤️ @Model.Note.Likes likes</span>
                </div>
            </div>

            <div class="note-brief">
                <div class="note-brief-label">Summary</div>
                <p>@Model.Note.BriefExplanation</p>
            </div>

            <div class="note-content-body">
                <p>@Model.Note.Content</p>
            </div>

            <div class="note-actions-bar">
                <form method="post" asp-page-handler="Like">
                    <input type="hidden" name="id" value="@Model.Note.Id" />
                    <input type="hidden" name="targetId" value="@Model.Note.CreatorId" />
                    <input type="hidden" name="doerId" value="@User.FindFirst(System.Security.Claims.ClaimTypes.NameIdentifier)?.Value" />
                    <button type="submit" class="action-btn">
                        <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z" /></svg>
                        Like (@Model.Note.Likes)
                    </button>
                </form>

                <form method="post" asp-page-handler="Save">
                    <input type="hidden" name="id" value="@Model.Note.Id" />
                    <button type="submit" class="action-btn">
                        <svg viewBox="0 0 24 24"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z" /></svg>
                        Save
                    </button>
                </form>

                @if (Model.IsOwner || User.IsInRole("Admin"))
                {
                    <a class="action-btn" asp-page="/Notes/Edit" asp-route-id="@Model.Note.Id">
                        <svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7" /><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z" /></svg>
                        Edit
                    </a>
                    <form method="post" asp-page-handler="Delete"
                          onsubmit="return confirm('Are you sure you want to delete this note?')">
                        <input type="hidden" name="id" value="@Model.Note.Id" />
                        <button type="submit" class="action-btn action-btn-danger">
                            <svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6" /><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6" /><path d="M10 11v6M14 11v6" /></svg>
                            Delete
                        </button>
                    </form>
                }
            </div>
        </div>

        <!-- AI Section -->
        <div class="ai-section">
            <div class="ai-section-header">
                <h3>🤖 AI Study Assistant</h3>
                <span class="ai-badge">Powered by Groq</span>
            </div>

            <div class="ai-tabs">
                <button class="ai-tab-btn active" onclick="switchAiTab('chat', this)">
                    💬 Ask a Question
                </button>
                <button class="ai-tab-btn" onclick="switchAiTab('summary', this)">
                    📋 Summarize Note
                </button>
            </div>

            <!-- Chat Tab -->
            <div class="ai-tab-panel active" id="ai-tab-chat">
                <div class="ai-chat-messages" id="chatMessages">
                    @if (Model.AiAnswer != null)
                    {
                        <div class="ai-message ai-message-user">@Model.UserQuestion</div>
                        <div class="ai-message ai-message-ai">
                            <div class="ai-message-ai-header">🤖 Groq</div>
                            <div id="aiAnswerDiv">@Model.AiAnswer</div>
                        </div>
                    }
                    else
                    {
                        <div class="ai-empty">
                            <div class="ai-empty-icon">🤖</div>
                            Ask me anything about this note — I'll help you understand it better!
                        </div>
                    }
                </div>

                <form method="post" asp-page-handler="Ask" id="askForm">
                    <input type="hidden" name="id" value="@Model.Note.Id" />
                    <div class="ai-input-row">
                        <textarea class="sb-input" asp-for="UserQuestion"
                                  placeholder="e.g. Can you explain the main concept? What are the key points?"
                                  rows="2" id="questionInput"></textarea>
                        <button type="submit" class="ai-submit-btn" id="askBtn">
                            Ask →
                        </button>
                    </div>
                </form>
            </div>

            <!-- Summary Tab -->
            <div class="ai-tab-panel" id="ai-tab-summary">
                @if (Model.AiSummary != null)
                {
                    <div class="ai-message-ai-header" style="margin-bottom:0.75rem;">🤖 Groq Summary</div>
                    <div class="ai-summary-box">
                        <div id="aiSummaryDiv">@Model.AiSummary</div>
                    </div>
                }
                else
                {
                    <div class="ai-empty">
                        <div class="ai-empty-icon">📋</div>
                        Click below to generate an AI summary of this note.
                    </div>
                }

                <form method="post" asp-page-handler="Summarize">
                    <input type="hidden" name="id" value="@Model.Note.Id" />
                    <button type="submit" class="ai-submit-btn" style="width:100%;">
                        ✨ Generate Summary
                    </button>
                </form>
            </div>
        </div>

        <!-- Comments -->
        <div class="comments-section">
            <h3>💬 Comments</h3>
            <div class="comment-input-row">
                <div class="comment-avatar">
                    @(User.Identity?.Name?.Substring(0, 1).ToUpper())
                </div>
                <div class="comment-input-wrap">
                    <textarea class="sb-input" rows="2" placeholder="Add a comment..." style="min-height:60px;"></textarea>
                    <div style="display:flex; justify-content:flex-end;">
                        <button class="btn-sb-primary" style="font-size:0.82rem; padding:0.35rem 0.9rem;">Post comment</button>
                    </div>
                </div>
            </div>
            <div class="empty-comments">No comments yet. Be the first to start the discussion!</div>
        </div>
    </div>

    <!-- Sidebar -->
    <div class="details-sidebar">
        <div class="sidebar-card">
            <h4>About the Author</h4>
            <div class="author-profile">
                <div class="author-avatar-lg">
                    @(Model.Note.Creator?.FirstName?.Substring(0, 1).ToUpper())@(Model.Note.Creator?.LastName?.Substring(0, 1).ToUpper())
                </div>
                <div class="author-name">@Model.Note.Creator?.FirstName @Model.Note.Creator?.LastName</div>
                <div class="author-nationality">@Model.Note.Creator?.Nationality</div>
            </div>
        </div>

        <div class="sidebar-card">
            <h4>Note Info</h4>
            <div style="display:flex; flex-direction:column; gap:0.6rem;">
                <div style="display:flex; justify-content:space-between; font-size:0.82rem;">
                    <span style="color:var(--text-muted);">Subject</span>
                    <span style="font-weight:500; color:var(--navy);">@Model.Note.Subject</span>
                </div>
                <div style="display:flex; justify-content:space-between; font-size:0.82rem;">
                    <span style="color:var(--text-muted);">Published</span>
                    <span style="font-weight:500; color:var(--navy);">@Model.Note.DateOfCreation.ToString("MMM dd, yyyy")</span>
                </div>
                <div style="display:flex; justify-content:space-between; font-size:0.82rem;">
                    <span style="color:var(--text-muted);">Likes</span>
                    <span style="font-weight:500; color:var(--navy);">@Model.Note.Likes</span>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        function switchAiTab(name, btn) {
            document.querySelectorAll('.ai-tab-panel').forEach(p => p.classList.remove('active'));
            document.querySelectorAll('.ai-tab-btn').forEach(b => b.classList.remove('active'));
            document.getElementById('ai-tab-' + name).classList.add('active');
            btn.classList.add('active');
        }

        // Ask form — typing indicator + optimistic user bubble
        document.getElementById('askForm')?.addEventListener('submit', function() {
            const btn = document.getElementById('askBtn');
            const messages = document.getElementById('chatMessages');
            const question = document.getElementById('questionInput')?.value?.trim();

            if (btn) { btn.innerHTML = '⏳ Thinking...'; btn.disabled = true; }

            if (messages && question) {
                const empty = messages.querySelector('.ai-empty');
                if (empty) empty.remove();

                const userBubble = document.createElement('div');
                userBubble.className = 'ai-message ai-message-user';
                userBubble.textContent = question;
                messages.appendChild(userBubble);

                const typing = document.createElement('div');
                typing.className = 'ai-typing';
                typing.innerHTML = '<div class="ai-typing-dot"></div><div class="ai-typing-dot"></div><div class="ai-typing-dot"></div>';
                messages.appendChild(typing);
                messages.scrollTop = messages.scrollHeight;
            }
        });

        // Summarize form — skeleton loader
        document.querySelector('form[asp-page-handler="Summarize"]')?.addEventListener('submit', function() {
            const panel = document.getElementById('ai-tab-summary');
            const btn = panel?.querySelector('button[type="submit"]');
            if (btn) { btn.innerHTML = '✨ Generating...'; btn.disabled = true; }

            const empty = panel?.querySelector('.ai-empty');
            if (empty) {
                empty.innerHTML = `
                    <div class="ai-skeleton" style="width:100%"></div>
                    <div class="ai-skeleton" style="width:88%"></div>
                    <div class="ai-skeleton" style="width:95%"></div>
                    <div class="ai-skeleton" style="width:80%"></div>
                    <div class="ai-skeleton"></div>`;
                empty.style.textAlign = 'left';
                empty.style.padding = '0';
            }
        });

        // Auto-switch tab if summary is present
        @if (Model.AiSummary != null)
        {
                <text>switchAiTab('summary', document.querySelectorAll('.ai-tab-btn')[1]);</text>
        }

        // Render markdown in AI responses
        function renderMarkdown() {
            if (typeof marked === 'undefined') return; // plain text already showing as fallback

            @if (Model.AiAnswer != null)
            {
                    <text>
                        var answerEl = document.getElementById('aiAnswerDiv');
                        if (answerEl) {
                            var answerRaw = @Html.Raw(Json.Serialize(Model.AiAnswer));
                            answerEl.innerHTML = marked.parse(answerRaw);
                            answerEl.classList.add('ai-markdown');
                        }
                    </text>
            }

            @if (Model.AiSummary != null)
            {
                    <text>
                        var summaryEl = document.getElementById('aiSummaryDiv');
                        if (summaryEl) {
                            var summaryRaw = @Html.Raw(Json.Serialize(Model.AiSummary));
                            summaryEl.innerHTML = marked.parse(summaryRaw);
                            summaryEl.classList.add('ai-markdown');
                        }
                    </text>
            }
        }

        if (document.readyState === 'loading') {
            document.addEventListener('DOMContentLoaded', renderMarkdown);
        } else {
            renderMarkdown();
        }

        // Scroll chat to bottom on load if there's a response
        @if (Model.AiAnswer != null)
        {
                <text>
                    const msgs = document.getElementById('chatMessages');
                    if (msgs) msgs.scrollTop = msgs.scrollHeight;
                </text>
        }
    </script>
}
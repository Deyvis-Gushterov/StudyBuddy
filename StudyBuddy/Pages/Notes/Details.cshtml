@page "{id:int}"
@model StudyBuddy.Pages.NotePages.DetailsModel
@{
    ViewData["Title"] = Model.Note?.Topic ?? "Note Details";
}

<style>
    .details-layout {
        display: grid;
        grid-template-columns: 1fr 300px;
        gap: 2rem;
        align-items: flex-start;
    }

    .note-content-card {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 14px;
        overflow: hidden;
        box-shadow: var(--card-shadow);
    }

    .note-content-header {
        padding: 2rem 2rem 1.5rem;
        border-bottom: 1px solid var(--border);
    }

    .note-subject-badge {
        display: inline-block;
        font-size: 0.72rem;
        font-weight: 600;
        color: var(--amber);
        background: #FEF3C7;
        border: 1px solid #FCD34D;
        padding: 3px 12px;
        border-radius: 20px;
        margin-bottom: 1rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .note-content-header h1 {
        font-size: 1.75rem;
        font-weight: 700;
        color: var(--navy);
        margin-bottom: 1rem;
        line-height: 1.3;
    }

    .note-meta {
        display: flex;
        align-items: center;
        gap: 1.25rem;
        flex-wrap: wrap;
    }

    .note-meta-author {
        display: flex;
        align-items: center;
        gap: 8px;
    }

    .note-meta-avatar {
        width: 32px;
        height: 32px;
        background: var(--navy);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 600;
        color: var(--amber);
    }

    .note-meta-author-info strong {
        font-size: 0.88rem;
        font-weight: 600;
        color: var(--navy);
        display: block;
    }

    .note-meta-author-info span {
        font-size: 0.78rem;
        color: var(--text-muted);
    }

    .note-meta-divider {
        width: 1px;
        height: 28px;
        background: var(--border);
    }

    .note-meta-stat {
        font-size: 0.82rem;
        color: var(--text-muted);
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .note-brief {
        padding: 1.5rem 2rem;
        background: var(--cream);
        border-bottom: 1px solid var(--border);
    }

    .note-brief-label {
        font-size: 0.72rem;
        font-weight: 600;
        color: var(--amber);
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 0.4rem;
    }

    .note-brief p {
        font-size: 0.95rem;
        color: var(--text-muted);
        margin: 0;
        line-height: 1.65;
        font-style: italic;
    }

    .note-content-body {
        padding: 2rem;
    }

    .note-content-body p {
        font-size: 0.95rem;
        line-height: 1.8;
        color: var(--text-dark);
        white-space: pre-wrap;
    }

    .note-actions-bar {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 1.25rem 2rem;
        border-top: 1px solid var(--border);
        background: var(--cream);
    }

    .action-btn {
        display: flex;
        align-items: center;
        gap: 6px;
        font-family: var(--font-body);
        font-size: 0.85rem;
        font-weight: 500;
        padding: 0.45rem 1rem;
        border-radius: 8px;
        border: 1.5px solid var(--border);
        background: var(--white);
        color: var(--text-muted);
        cursor: pointer;
        transition: all 0.15s;
        text-decoration: none;
    }

    .action-btn:hover {
        border-color: var(--navy);
        color: var(--navy);
        text-decoration: none;
    }

    .action-btn.liked {
        border-color: #EF4444;
        color: #EF4444;
        background: #FEE2E2;
    }

    .action-btn.saved {
        border-color: var(--amber);
        color: var(--amber);
        background: #FEF3C7;
    }

    .action-btn svg {
        width: 15px;
        height: 15px;
        stroke: currentColor;
        fill: none;
    }

    .action-btn-danger {
        border-color: #FCA5A5;
        color: #EF4444;
        margin-left: auto;
    }

    .action-btn-danger:hover {
        border-color: #EF4444;
        background: #FEE2E2;
        color: #EF4444;
    }

    /* Sidebar */
    .details-sidebar {
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .sidebar-card {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1.25rem 1.5rem;
    }

    .sidebar-card h4 {
        font-size: 0.88rem;
        font-weight: 600;
        color: var(--navy);
        margin-bottom: 1rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid var(--border);
    }

    .author-profile {
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        gap: 0.5rem;
    }

    .author-avatar-lg {
        width: 56px;
        height: 56px;
        background: var(--navy);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 18px;
        font-weight: 700;
        color: var(--amber);
        margin-bottom: 0.25rem;
    }

    .author-name {
        font-weight: 600;
        color: var(--navy);
        font-size: 0.95rem;
    }

    .author-nationality {
        font-size: 0.8rem;
        color: var(--text-muted);
    }

    /* Comments placeholder */
    .comments-section {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1.5rem 2rem;
        box-shadow: var(--card-shadow);
        margin-top: 1.5rem;
    }

    .comments-section h3 {
        font-size: 1.1rem;
        color: var(--navy);
        margin-bottom: 1.5rem;
        padding-bottom: 0.75rem;
        border-bottom: 1px solid var(--border);
    }

    .comment-input-row {
        display: flex;
        gap: 0.75rem;
        align-items: flex-start;
        margin-bottom: 1.5rem;
    }

    .comment-avatar {
        width: 32px;
        height: 32px;
        min-width: 32px;
        background: var(--navy);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 10px;
        font-weight: 600;
        color: var(--amber);
    }

    .comment-input-wrap {
        flex: 1;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
    }

    .empty-comments {
        text-align: center;
        padding: 2rem;
        color: var(--text-muted);
        font-size: 0.9rem;
    }

    @@media (max-width: 768px) {
        .details-layout { grid-template-columns: 1fr; }
        .note-content-header { padding: 1.5rem; }
        .note-content-body { padding: 1.5rem; }
        .note-actions-bar { padding: 1rem 1.5rem; flex-wrap: wrap; }
    }
</style>

@if (Model.Note == null)
{
    <div class="sb-alert sb-alert-danger">Note not found.</div>
    return;
}

<!-- Back -->
<div style="margin-bottom: 1.5rem;">
    <a class="btn-sb-ghost" asp-page="/Notes/Index">← Back to Notes</a>
</div>

<div class="details-layout">
    <div>
        <!-- Main Note Card -->
        <div class="note-content-card">
            <div class="note-content-header">
                <span class="note-subject-badge">@Model.Note.Subject</span>
                <h1>@Model.Note.Topic</h1>
                <div class="note-meta">
                    <div class="note-meta-author">
                        <div class="note-meta-avatar">
                            @(Model.Note.Creator?.FirstName?.Substring(0,1).ToUpper())@(Model.Note.Creator?.LastName?.Substring(0,1).ToUpper())
                        </div>
                        <div class="note-meta-author-info">
                            <strong>@Model.Note.Creator?.FirstName @Model.Note.Creator?.LastName</strong>
                            <span>@Model.Note.DateOfCreation.ToString("MMMM dd, yyyy")</span>
                        </div>
                    </div>
                    <div class="note-meta-divider"></div>
                    <span class="note-meta-stat">
                        ❤️ @Model.Note.Likes likes
                    </span>
                </div>
            </div>

            <div class="note-brief">
                <div class="note-brief-label">Summary</div>
                <p>@Model.Note.BriefExplanation</p>
            </div>

            <div class="note-content-body">
                <p>@Model.Note.Content</p>
            </div>

            <!-- Action Bar -->
            <div class="note-actions-bar">
                <form method="post" asp-page-handler="Like">
                    <input type="hidden" name="id" value="@Model.Note.Id" />
                    <button type="submit" class="action-btn">
                        <svg viewBox="0 0 24 24"><path d="M20.84 4.61a5.5 5.5 0 0 0-7.78 0L12 5.67l-1.06-1.06a5.5 5.5 0 0 0-7.78 7.78l1.06 1.06L12 21.23l7.78-7.78 1.06-1.06a5.5 5.5 0 0 0 0-7.78z"/></svg>
                        Like (@Model.Note.Likes)
                    </button>
                </form>

                <form method="post" asp-page-handler="Save">
                    <input type="hidden" name="id" value="@Model.Note.Id" />
                    <button type="submit" class="action-btn">
                        <svg viewBox="0 0 24 24"><path d="M19 21l-7-5-7 5V5a2 2 0 0 1 2-2h10a2 2 0 0 1 2 2z"/></svg>
                        Save
                    </button>
                </form>

                @if (Model.IsOwner || User.IsInRole("Admin"))
                {
                    <a class="action-btn" asp-page="/Notes/Edit" asp-route-id="@Model.Note.Id">
                        <svg viewBox="0 0 24 24"><path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"/><path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"/></svg>
                        Edit
                    </a>
                    <form method="post" asp-page-handler="Delete" onsubmit="return confirm('Are you sure you want to delete this note?')">
                        <input type="hidden" name="id" value="@Model.Note.Id" />
                        <button type="submit" class="action-btn action-btn-danger">
                            <svg viewBox="0 0 24 24"><polyline points="3 6 5 6 21 6"/><path d="M19 6l-1 14a2 2 0 0 1-2 2H8a2 2 0 0 1-2-2L5 6"/><path d="M10 11v6M14 11v6"/></svg>
                            Delete
                        </button>
                    </form>
                }
            </div>
        </div>

        <!-- Comments -->
        <div class="comments-section">
            <h3>💬 Comments</h3>
            <div class="comment-input-row">
                <div class="comment-avatar">
                    @(User.Identity?.Name?.Substring(0,1).ToUpper())
                </div>
                <div class="comment-input-wrap">
                    <textarea class="sb-input" rows="2" placeholder="Add a comment..." style="min-height:60px;"></textarea>
                    <div style="display:flex; justify-content:flex-end;">
                        <button class="btn-sb-primary" style="font-size:0.82rem; padding:0.35rem 0.9rem;">Post comment</button>
                    </div>
                </div>
            </div>
            <div class="empty-comments">
                No comments yet. Be the first to start the discussion!
            </div>
        </div>
    </div>

    <!-- Sidebar -->
    <div class="details-sidebar">
        <div class="sidebar-card">
            <h4>About the Author</h4>
            <div class="author-profile">
                <div class="author-avatar-lg">
                    @(Model.Note.Creator?.FirstName?.Substring(0,1).ToUpper())@(Model.Note.Creator?.LastName?.Substring(0,1).ToUpper())
                </div>
                <div class="author-name">@Model.Note.Creator?.FirstName @Model.Note.Creator?.LastName</div>
                <div class="author-nationality">@Model.Note.Creator?.Nationality</div>
            </div>
        </div>

        <div class="sidebar-card">
            <h4>Note Info</h4>
            <div style="display:flex; flex-direction:column; gap:0.6rem;">
                <div style="display:flex; justify-content:space-between; font-size:0.82rem;">
                    <span style="color:var(--text-muted);">Subject</span>
                    <span style="font-weight:500; color:var(--navy);">@Model.Note.Subject</span>
                </div>
                <div style="display:flex; justify-content:space-between; font-size:0.82rem;">
                    <span style="color:var(--text-muted);">Published</span>
                    <span style="font-weight:500; color:var(--navy);">@Model.Note.DateOfCreation.ToString("MMM dd, yyyy")</span>
                </div>
                <div style="display:flex; justify-content:space-between; font-size:0.82rem;">
                    <span style="color:var(--text-muted);">Likes</span>
                    <span style="font-weight:500; color:var(--navy);">@Model.Note.Likes</span>
                </div>
            </div>
        </div>

        <div class="sidebar-card" style="background:var(--cream);">
            <h4>🤖 AI Study Assistant</h4>
            <p style="font-size:0.82rem; color:var(--text-muted); margin:0;">
                Ask questions about this note, get a summary, or quiz yourself — coming soon!
            </p>
        </div>
    </div>
</div>

@page
@model StudyBuddy.Pages.Feed.IndexModel
@using System.Security.Claims
@using System.Text.RegularExpressions
@{
    ViewData["Title"] = "Feed";
    var currentUserId = User.FindFirst(ClaimTypes.NameIdentifier)?.Value;
    var currentUserInitial = User.Identity?.Name?.Substring(0, 1).ToUpper() ?? "U";
}

@functions {
    string GetTimeAgo(DateTime utcTime)
    {
        var diff = DateTime.UtcNow - utcTime;
        if (diff.TotalSeconds < 60) return "Just now";
        if (diff.TotalMinutes < 60) return $"{(int)diff.TotalMinutes}m ago";
        if (diff.TotalHours < 24) return $"{(int)diff.TotalHours}h ago";
        if (diff.TotalDays < 7) return $"{(int)diff.TotalDays}d ago";
        return utcTime.ToLocalTime().ToString("MMM d");
    }

    string RenderContent(string content)
    {
        if (string.IsNullOrEmpty(content)) return "";
        // Linkify hashtags
        return Regex.Replace(content, @"#(\w+)", m =>
            $"<a href='/Feed/Tag?tag={m.Groups[1].Value.ToLower()}' class='post-hashtag'>#{m.Groups[1].Value}</a>");
    }
}

<style>
    .feed-layout {
        display: grid;
        grid-template-columns: 1fr 300px;
        gap: 2rem;
        align-items: flex-start;
        max-width: 900px;
        margin: 0 auto;
    }

    .composer-card {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 1.25rem 1.5rem;
        box-shadow: var(--card-shadow);
        margin-bottom: 1.5rem;
        animation: fadeInUp 0.35s ease both;
    }

    .composer-row {
        display: flex;
        gap: 0.75rem;
        align-items: flex-start;
    }

    .composer-avatar {
        width: 38px;
        height: 38px;
        min-width: 38px;
        background: var(--navy);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 13px;
        font-weight: 700;
        color: var(--amber);
    }

    .composer-wrap {
        flex: 1;
    }

    .composer-textarea {
        width: 100%;
        border: 1.5px solid var(--border);
        border-radius: 12px;
        padding: 0.75rem 1rem;
        font-family: var(--font-body);
        font-size: 0.925rem;
        color: var(--text-dark);
        background: var(--cream);
        resize: none;
        outline: none;
        min-height: 80px;
        transition: border-color 0.15s, background 0.15s;
        line-height: 1.6;
    }

        .composer-textarea:focus {
            border-color: var(--navy);
            background: var(--white);
        }

        .composer-textarea::placeholder {
            color: var(--text-muted);
        }

    .composer-image-preview {
        position: relative;
        margin-top: 0.75rem;
        border-radius: 12px;
        overflow: hidden;
        display: none;
    }

        .composer-image-preview img {
            width: 100%;
            max-height: 240px;
            object-fit: cover;
            border-radius: 12px;
            border: 1px solid var(--border);
        }

    .composer-image-remove {
        position: absolute;
        top: 8px;
        right: 8px;
        width: 28px;
        height: 28px;
        background: rgba(0,0,0,0.6);
        color: white;
        border: none;
        border-radius: 50%;
        cursor: pointer;
        font-size: 0.85rem;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.15s;
    }

        .composer-image-remove:hover {
            background: rgba(239,68,68,0.9);
        }

    .composer-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-top: 0.75rem;
        gap: 0.5rem;
    }

    .composer-actions {
        display: flex;
        align-items: center;
        gap: 0.5rem;
    }

    .composer-char {
        font-size: 0.75rem;
        color: var(--text-muted);
    }

        .composer-char.warning {
            color: #D97706;
        }

        .composer-char.danger {
            color: #DC2626;
        }

    .upload-btn {
        display: flex;
        align-items: center;
        gap: 5px;
        font-family: var(--font-body);
        font-size: 0.8rem;
        font-weight: 500;
        color: var(--text-muted);
        background: var(--cream);
        border: 1.5px solid var(--border);
        padding: 0.35rem 0.85rem;
        border-radius: 8px;
        cursor: pointer;
        transition: all 0.15s;
    }

        .upload-btn:hover {
            border-color: var(--navy);
            color: var(--navy);
        }

    .feed-list {
        display: flex;
        flex-direction: column;
        gap: 1rem;
    }

    .post-card {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 16px;
        overflow: hidden;
        box-shadow: var(--card-shadow);
        transition: box-shadow 0.2s ease, transform 0.2s ease;
        animation: fadeInUp 0.4s ease both;
    }

        .post-card:hover {
            box-shadow: 0 6px 24px rgba(27,42,74,0.1);
            transform: translateY(-1px);
        }

    .post-card-inner {
        padding: 1.25rem 1.5rem;
    }

    .post-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        margin-bottom: 0.875rem;
    }

    .post-author {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        text-decoration: none;
        transition: opacity 0.15s;
    }

        .post-author:hover {
            opacity: 0.75;
        }

    .post-avatar {
        width: 36px;
        height: 36px;
        background: var(--navy);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 12px;
        font-weight: 700;
        color: var(--amber);
        flex-shrink: 0;
    }

    .post-author-info strong {
        font-size: 0.875rem;
        font-weight: 600;
        color: var(--navy);
        display: block;
    }

    .post-author-info span {
        font-size: 0.75rem;
        color: var(--text-muted);
    }

    .post-content {
        font-size: 0.95rem;
        line-height: 1.75;
        color: var(--text-dark);
        margin-bottom: 0.875rem;
        white-space: pre-wrap;
        word-break: break-word;
    }

    /* Hashtags */
    .post-hashtag {
        color: var(--amber);
        font-weight: 600;
        text-decoration: none;
        transition: color 0.15s;
    }

        .post-hashtag:hover {
            color: var(--navy);
            text-decoration: underline;
        }

    /* Post tags row */
    .post-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 5px;
        margin-bottom: 0.75rem;
    }

    .post-tag {
        font-size: 0.72rem;
        font-weight: 600;
        color: var(--amber);
        background: #FEF3C7;
        border: 1px solid #FCD34D;
        padding: 2px 8px;
        border-radius: 20px;
        text-decoration: none;
        transition: all 0.15s;
    }

        .post-tag:hover {
            background: var(--amber);
            color: var(--white);
        }

    .post-image {
        width: 100%;
        max-height: 480px;
        object-fit: cover;
        display: block;
        cursor: zoom-in;
        transition: opacity 0.15s;
    }

        .post-image:hover {
            opacity: 0.95;
        }

    .post-footer {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        padding: 0.75rem 1.5rem;
        border-top: 1px solid var(--border);
        background: var(--cream);
    }

    .post-action-btn {
        display: flex;
        align-items: center;
        gap: 5px;
        font-family: var(--font-body);
        font-size: 0.8rem;
        font-weight: 500;
        padding: 0.35rem 0.85rem;
        border-radius: 8px;
        border: 1.5px solid var(--border);
        background: var(--white);
        color: var(--text-muted);
        cursor: pointer;
        transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
        text-decoration: none;
    }

        .post-action-btn:hover {
            border-color: var(--navy);
            color: var(--navy);
            transform: translateY(-1px);
            box-shadow: 0 3px 10px rgba(27,42,74,0.1);
            text-decoration: none;
        }

        .post-action-btn:active {
            transform: scale(0.96);
        }

        .post-action-btn.like-btn:hover {
            border-color: #FCA5A5;
            color: #EF4444;
            background: #FEF2F2;
        }

        .post-action-btn.comment-btn:hover {
            border-color: var(--navy);
            color: var(--navy);
        }

        .post-action-btn.delete-btn {
            margin-left: auto;
            border-color: transparent;
            background: transparent;
        }

            .post-action-btn.delete-btn:hover {
                border-color: #FCA5A5;
                color: #EF4444;
                background: #FEF2F2;
                box-shadow: none;
                transform: none;
            }

    /* Comments section */
    .post-comments {
        border-top: 1px solid var(--border);
        padding: 1rem 1.5rem;
        display: none;
        flex-direction: column;
        gap: 0.75rem;
        background: var(--cream);
    }

        .post-comments.open {
            display: flex;
        }

    .post-comment-item {
        display: flex;
        gap: 0.6rem;
        align-items: flex-start;
        animation: fadeInUp 0.25s ease both;
    }

    .post-comment-avatar {
        width: 28px;
        height: 28px;
        min-width: 28px;
        background: var(--navy);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 9px;
        font-weight: 700;
        color: var(--amber);
    }

    .post-comment-body {
        flex: 1;
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 10px;
        padding: 0.6rem 0.85rem;
    }

    .post-comment-author {
        font-size: 0.78rem;
        font-weight: 600;
        color: var(--navy);
        text-decoration: none;
        display: block;
        margin-bottom: 2px;
    }

        .post-comment-author:hover {
            color: var(--amber);
        }

    .post-comment-text {
        font-size: 0.85rem;
        color: var(--text-dark);
        margin: 0;
        line-height: 1.5;
    }

    /* Comment input */
    .post-comment-form {
        display: flex;
        gap: 0.5rem;
        align-items: center;
        margin-top: 0.25rem;
    }

    .post-comment-input {
        flex: 1;
        border: 1.5px solid var(--border);
        border-radius: 20px;
        padding: 0.4rem 0.85rem;
        font-family: var(--font-body);
        font-size: 0.85rem;
        outline: none;
        background: var(--white);
        transition: border-color 0.15s;
    }

        .post-comment-input:focus {
            border-color: var(--navy);
        }

    .post-comment-submit {
        font-family: var(--font-body);
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--white);
        background: var(--navy);
        border: none;
        padding: 0.4rem 0.85rem;
        border-radius: 20px;
        cursor: pointer;
        transition: background 0.15s;
        white-space: nowrap;
    }

        .post-comment-submit:hover {
            background: var(--navy-light);
        }

    /* Lightbox */
    .lightbox {
        display: none;
        position: fixed;
        inset: 0;
        background: rgba(0,0,0,0.88);
        z-index: 9999;
        align-items: center;
        justify-content: center;
        cursor: zoom-out;
        animation: fadeIn 0.2s ease;
    }

        .lightbox.open {
            display: flex;
        }

        .lightbox img {
            max-width: 90vw;
            max-height: 90vh;
            object-fit: contain;
            border-radius: 8px;
            box-shadow: 0 20px 60px rgba(0,0,0,0.5);
        }

    .feed-empty {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 3rem 2rem;
        text-align: center;
        box-shadow: var(--card-shadow);
    }

    .feed-empty-icon {
        font-size: 3rem;
        margin-bottom: 1rem;
    }

    .feed-empty h3 {
        font-size: 1.1rem;
        color: var(--navy);
        margin-bottom: 0.5rem;
    }

    .feed-empty p {
        font-size: 0.875rem;
        color: var(--text-muted);
        margin: 0;
    }

    .feed-sidebar {
        position: sticky;
        top: 80px;
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
    }

    .sidebar-card {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 14px;
        padding: 1.25rem 1.5rem;
        box-shadow: var(--card-shadow);
        animation: slideInRight 0.4s ease both;
    }

        .sidebar-card h4 {
            font-size: 0.82rem;
            font-weight: 700;
            color: var(--navy);
            margin-bottom: 1rem;
            padding-bottom: 0.6rem;
            border-bottom: 1px solid var(--border);
            text-transform: uppercase;
            letter-spacing: 0.4px;
        }

    .suggested-user {
        display: flex;
        align-items: center;
        gap: 0.75rem;
        padding: 0.6rem 0;
        border-bottom: 1px solid var(--border);
    }

        .suggested-user:last-child {
            border-bottom: none;
        }

    .suggested-avatar {
        width: 34px;
        height: 34px;
        background: var(--navy);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 11px;
        font-weight: 700;
        color: var(--amber);
        flex-shrink: 0;
        text-decoration: none;
    }

    .suggested-info {
        flex: 1;
        min-width: 0;
    }

        .suggested-info a {
            font-size: 0.85rem;
            font-weight: 600;
            color: var(--navy);
            text-decoration: none;
            display: block;
            white-space: nowrap;
            overflow: hidden;
            text-overflow: ellipsis;
        }

            .suggested-info a:hover {
                color: var(--amber);
            }

        .suggested-info span {
            font-size: 0.75rem;
            color: var(--text-muted);
        }

    .follow-btn {
        font-family: var(--font-body);
        font-size: 0.75rem;
        font-weight: 600;
        color: var(--navy);
        background: var(--cream);
        border: 1.5px solid var(--border);
        padding: 0.25rem 0.75rem;
        border-radius: 20px;
        cursor: pointer;
        transition: all 0.2s cubic-bezier(0.34, 1.56, 0.64, 1);
        white-space: nowrap;
    }

        .follow-btn:hover {
            background: var(--navy);
            color: var(--white);
            border-color: var(--navy);
            transform: scale(1.05);
        }

    @@keyframes fadeInUp {
        from {
            opacity: 0;
            transform: translateY(16px);
        }

        to {
            opacity: 1;
            transform: translateY(0);
        }
    }

    @@keyframes slideInRight {
        from {
            opacity: 0;
            transform: translateX(16px);
        }

        to {
            opacity: 1;
            transform: translateX(0);
        }
    }

    @@keyframes fadeIn {
        from {
            opacity: 0;
        }

        to {
            opacity: 1;
        }
    }

    .post-card:nth-child(1) {
        animation-delay: 0.05s;
    }

    .post-card:nth-child(2) {
        animation-delay: 0.10s;
    }

    .post-card:nth-child(3) {
        animation-delay: 0.15s;
    }

    .post-card:nth-child(4) {
        animation-delay: 0.20s;
    }

    .post-card:nth-child(5) {
        animation-delay: 0.25s;
    }

    .sidebar-card:nth-child(1) {
        animation-delay: 0.1s;
    }

    .sidebar-card:nth-child(2) {
        animation-delay: 0.2s;
    }

    @@media (max-width: 768px) {
        .feed-layout {
            grid-template-columns: 1fr;
        }

        .feed-sidebar {
            position: static;
        }
    }
</style>

<!-- Lightbox -->
<div class="lightbox" id="lightbox" onclick="closeLightbox()">
    <img id="lightboxImg" src="" alt="Post image" />
</div>

<div class="feed-layout">
    <div>
        <!-- Composer -->
        <div class="composer-card">
            <form method="post" asp-page-handler="Create" id="composerForm"
                  enctype="multipart/form-data">
                <div class="composer-row">
                    <div class="composer-avatar">@currentUserInitial</div>
                    <div class="composer-wrap">
                        <textarea class="composer-textarea"
                                  name="content" id="composerInput"
                                  placeholder="What's on your mind? Use #hashtags to categorize your post 📸"
                                  maxlength="300"></textarea>

                        <div class="composer-image-preview" id="imagePreview">
                            <img id="previewImg" src="" alt="Preview" />
                            <button type="button" class="composer-image-remove"
                                    onclick="removeImage()">
                                ✕
                            </button>
                        </div>

                        <div class="composer-footer">
                            <div class="composer-actions">
                                <input type="file" name="image" id="imageInput"
                                       accept="image/*" style="display:none;"
                                       onchange="previewImage(this)" />
                                <label for="imageInput" class="upload-btn">📷 Photo</label>
                                <span class="composer-char" id="composerCount">0 / 300</span>
                            </div>
                            <button type="submit" class="btn-sb-primary"
                                    style="font-size:0.85rem; padding:0.4rem 1.25rem;"
                                    id="postBtn">
                                Post
                            </button>
                        </div>
                    </div>
                </div>
            </form>
        </div>

        <!-- Feed -->
        <div class="feed-list">
            @if (!Model.Posts.Any())
            {
                <div class="feed-empty">
                    <div class="feed-empty-icon">🌱</div>
                    <h3>Your feed is empty</h3>
                    <p>Follow some students to see their posts, or be the first to post something!</p>
                </div>
            }
            else
            {
                @foreach (var post in Model.Posts)
                {
                    var initials = $"{post.Author?.FirstName?.Substring(0, 1)}{post.Author?.LastName?.Substring(0, 1)}".ToUpper();
                    var timeAgo = GetTimeAgo(post.CreatedAt);
                    var isOwner = post.AuthorId == currentUserId;
                    var commentCount = post.Comments?.Count ?? 0;
                    var tags = (post.Tags ?? "").Split(',', StringSplitOptions.RemoveEmptyEntries);

                    <div class="post-card">
                        <div class="post-card-inner">
                            <div class="post-header">
                                <a class="post-author"
                                   asp-page="/Profile/Index"
                                   asp-route-userId="@post.AuthorId">
                                    <div class="post-avatar">@initials</div>
                                    <div class="post-author-info">
                                        <strong>@post.Author?.FirstName @post.Author?.LastName</strong>
                                        <span>@timeAgo</span>
                                    </div>
                                </a>
                            </div>

                            @if (!string.IsNullOrEmpty(post.Content))
                            {
                                <div class="post-content">@Html.Raw(RenderContent(post.Content))</div>
                            }

                            @if (tags.Any())
                            {
                                <div class="post-tags">
                                    @foreach (var tag in tags)
                                    {
                                        <a class="post-tag" href="/Feed/Tag?tag=@tag">#@tag</a>
                                    }
                                </div>
                            }
                        </div>

                        @if (!string.IsNullOrEmpty(post.ImageUrl))
                        {
                            <img class="post-image" src="@post.ImageUrl" alt="Post image"
                                 onclick="openLightbox('@post.ImageUrl')" />
                        }

                        <div class="post-footer">
                            <form method="post" asp-page-handler="Like">
                                <input type="hidden" name="id" value="@post.Id" />
                                <input type="hidden" name="targetId" value="@post.AuthorId" />
                                <input type="hidden" name="doerId" value="@currentUserId" />
                                <button type="submit" class="post-action-btn like-btn">
                                    ❤️ @post.Likes
                                </button>
                            </form>

                            <button class="post-action-btn comment-btn"
                                    onclick="toggleComments(@post.Id)">
                                💬 @commentCount
                            </button>

                            @if (isOwner || User.IsInRole("Admin"))
                            {
                                <form method="post" asp-page-handler="Delete"
                                      onsubmit="return confirm('Delete this post?')">
                                    <input type="hidden" name="id" value="@post.Id" />
                                    <button type="submit" class="post-action-btn delete-btn"
                                            title="Delete">
                                        🗑️
                                    </button>
                                </form>
                            }
                        </div>

                        <!-- Comments -->
                        <div class="post-comments @(commentCount > 0 ? "open" : "")" id="comments-@post.Id">
                            @if (post.Comments != null && post.Comments.Any())
                            {
                                @foreach (var comment in post.Comments.OrderBy(c => c.Id))
                                {
                                    var cInitials = $"{comment.Author?.FirstName?.Substring(0, 1)}{comment.Author?.LastName?.Substring(0, 1)}".ToUpper();
                                    <div class="post-comment-item">
                                        <div class="post-comment-avatar">@cInitials</div>
                                        <div class="post-comment-body">
                                            <a class="post-comment-author"
                                               asp-page="/Profile/Index"
                                               asp-route-userId="@comment.AuthorId">
                                                @comment.Author?.FirstName @comment.Author?.LastName
                                            </a>
                                            <p class="post-comment-text">@comment.Content</p>
                                        </div>
                                    </div>
                                }
                            }

                            <!-- Comment input -->
                            <div class="post-comment-form">
                                <div class="post-comment-avatar">@currentUserInitial</div>
                                <form method="post" asp-page-handler="Comment"
                                      style="display:flex; gap:0.5rem; flex:1;">
                                    <input type="hidden" name="postId" value="@post.Id" />
                                    <input class="post-comment-input" name="content"
                                           placeholder="Write a comment..." required />
                                    <button type="submit" class="post-comment-submit">Post</button>
                                </form>
                            </div>
                        </div>
                    </div>
                }
            }
        </div>
    </div>

    <!-- Sidebar -->
    <div class="feed-sidebar">
        <div class="sidebar-card">
            <h4>👥 Suggested Students</h4>
            @if (!Model.SuggestedUsers.Any())
            {
                <p style="font-size:0.82rem; color:var(--text-muted); margin:0;">
                    You're following everyone! 🎉
                </p>
            }
            else
            {
                @foreach (var u in Model.SuggestedUsers)
                {
                    var uInitials = $"{u.FirstName?.Substring(0, 1)}{u.LastName?.Substring(0, 1)}".ToUpper();
                    <div class="suggested-user">
                        <a class="suggested-avatar" asp-page="/Profile/Index"
                           asp-route-userId="@u.Id">@uInitials</a>
                        <div class="suggested-info">
                            <a asp-page="/Profile/Index" asp-route-userId="@u.Id">
                                @u.FirstName @u.LastName
                            </a>
                            <span>@u.Nationality</span>
                        </div>
                        <form method="post" asp-page="/Profile/Index"
                              asp-page-handler="Follow" asp-route-userId="@u.Id">
                            <input type="hidden" name="targetId" value="@u.Id" />
                            <button type="submit" class="follow-btn">Follow</button>
                        </form>
                    </div>
                }
            }
        </div>

        <div class="sidebar-card">
            <h4>🔗 Quick Links</h4>
            <div style="display:flex; flex-direction:column; gap:0.5rem;">
                <a asp-page="/Notes/Create" class="post-action-btn" style="justify-content:center;">
                    📝 Write a Note
                </a>
                <a asp-page="/Blogs/Create" class="post-action-btn" style="justify-content:center;">
                    ✍️ Write a Blog
                </a>
                <a asp-page="/Notes/Index" class="post-action-btn" style="justify-content:center;">
                    📚 Browse Notes
                </a>
                <a asp-page="/Blogs/Index" class="post-action-btn" style="justify-content:center;">
                    🌐 Browse Blogs
                </a>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <script>
        // Composer
        const input = document.getElementById('composerInput');
        const count = document.getElementById('composerCount');

        if (input && count) {
            input.addEventListener('input', () => {
                const len = input.value.length;
                count.textContent = `${len} / 300`;
                count.className = 'composer-char';
                if (len > 240) count.classList.add('warning');
                if (len >= 290) count.classList.add('danger');
                input.style.height = 'auto';
                input.style.height = Math.min(input.scrollHeight, 200) + 'px';
            });
        }

        // Image preview
        function previewImage(input) {
            const file = input.files[0];
            if (!file) return;
            const preview = document.getElementById('imagePreview');
            const img = document.getElementById('previewImg');
            const reader = new FileReader();
            reader.onload = e => { img.src = e.target.result; preview.style.display = 'block'; };
            reader.readAsDataURL(file);
        }

        function removeImage() {
            document.getElementById('imageInput').value = '';
            document.getElementById('previewImg').src = '';
            document.getElementById('imagePreview').style.display = 'none';
        }

        // Lightbox
        function openLightbox(src) {
            document.getElementById('lightboxImg').src = src;
            document.getElementById('lightbox').classList.add('open');
            document.body.style.overflow = 'hidden';
        }

        function closeLightbox() {
            document.getElementById('lightbox').classList.remove('open');
            document.body.style.overflow = '';
        }

        document.addEventListener('keydown', e => { if (e.key === 'Escape') closeLightbox(); });

        // Toggle comments
        function toggleComments(postId) {
            const section = document.getElementById(`comments-${postId}`);
            if (section) section.classList.toggle('open');
        }

        // Post loading state
        document.getElementById('composerForm')?.addEventListener('submit', () => {
            const btn = document.getElementById('postBtn');
            if (btn) { btn.textContent = 'Posting...'; btn.disabled = true; }
        });
    </script>
}

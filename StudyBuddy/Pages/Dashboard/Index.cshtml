@page
@model StudyBuddy.Pages.Dashboard.IndexModel
@{
    ViewData["Title"] = "My Dashboard";
}

<style>
    /* ── Profile Header ── */
    .dashboard-header {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 16px;
        padding: 2rem;
        margin-bottom: 2rem;
        box-shadow: var(--card-shadow);
        display: flex;
        align-items: center;
        gap: 2rem;
        flex-wrap: wrap;
    }

    .dashboard-avatar {
        width: 80px;
        height: 80px;
        min-width: 80px;
        background: var(--navy);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-family: var(--font-heading);
        font-size: 2rem;
        font-weight: 700;
        color: var(--amber);
        border: 3px solid var(--amber);
    }

    .dashboard-info { flex: 1; }

    .dashboard-name {
        font-family: var(--font-heading);
        font-size: 1.6rem;
        font-weight: 700;
        color: var(--navy);
        margin: 0 0 0.25rem;
    }

    .dashboard-email {
        font-size: 0.875rem;
        color: var(--text-muted);
        margin: 0 0 0.75rem;
    }

    .dashboard-meta {
        display: flex;
        gap: 1rem;
        flex-wrap: wrap;
    }

    .dashboard-meta-item {
        display: flex;
        align-items: center;
        gap: 5px;
        font-size: 0.8rem;
        color: var(--text-muted);
        background: var(--cream);
        padding: 3px 10px;
        border-radius: 20px;
        border: 1px solid var(--border);
    }

    .dashboard-stats {
        display: flex;
        gap: 2rem;
        flex-wrap: wrap;
    }

    .dashboard-stat {
        text-align: center;
    }

    .dashboard-stat-num {
        font-family: var(--font-heading);
        font-size: 1.5rem;
        font-weight: 700;
        color: var(--navy);
        display: block;
    }

    .dashboard-stat-label {
        font-size: 0.75rem;
        color: var(--text-muted);
    }

    .dashboard-stat-divider {
        width: 1px;
        height: 40px;
        background: var(--border);
        align-self: center;
    }

    .dashboard-actions {
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        align-items: flex-end;
    }

    /* ── Tabs ── */
    .dashboard-tabs {
        display: flex;
        gap: 0.25rem;
        border-bottom: 2px solid var(--border);
        margin-bottom: 2rem;
        overflow-x: auto;
        padding-bottom: 0;
    }

    .tab-btn {
        font-family: var(--font-body);
        font-size: 0.875rem;
        font-weight: 500;
        color: var(--text-muted);
        background: transparent;
        border: none;
        padding: 0.75rem 1.25rem;
        cursor: pointer;
        border-bottom: 2px solid transparent;
        margin-bottom: -2px;
        transition: all 0.15s;
        white-space: nowrap;
        display: flex;
        align-items: center;
        gap: 6px;
    }

    .tab-btn:hover { color: var(--navy); }

    .tab-btn.active {
        color: var(--navy);
        border-bottom-color: var(--navy);
        font-weight: 600;
    }

    .tab-count {
        background: var(--cream);
        border: 1px solid var(--border);
        font-size: 0.7rem;
        font-weight: 600;
        padding: 1px 7px;
        border-radius: 20px;
        color: var(--text-muted);
    }

    .tab-btn.active .tab-count {
        background: var(--navy);
        border-color: var(--navy);
        color: var(--white);
    }

    /* ── Tab Panels ── */
    .tab-panel { display: none; }
    .tab-panel.active { display: block; }

    /* ── Notes Grid ── */
    .dashboard-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(280px, 1fr));
        gap: 1.25rem;
    }

    .dash-note-card {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1.25rem;
        transition: all 0.2s ease;
        display: flex;
        flex-direction: column;
        gap: 0.6rem;
        position: relative;
    }

    .dash-note-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(27,42,74,0.1);
    }

    .dash-card-subject {
        font-size: 0.7rem;
        font-weight: 600;
        color: var(--amber);
        text-transform: uppercase;
        letter-spacing: 0.5px;
    }

    .dash-card-title {
        font-family: var(--font-heading);
        font-size: 1rem;
        font-weight: 600;
        color: var(--navy);
        margin: 0;
        line-height: 1.3;
    }

    .dash-card-excerpt {
        font-size: 0.82rem;
        color: var(--text-muted);
        line-height: 1.5;
        margin: 0;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .dash-card-footer {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding-top: 0.6rem;
        border-top: 1px solid var(--border);
        margin-top: auto;
    }

    .dash-card-stat {
        font-size: 0.75rem;
        color: var(--text-muted);
        display: flex;
        align-items: center;
        gap: 4px;
    }

    .dash-card-actions {
        display: flex;
        gap: 0.4rem;
    }

    .dash-card-btn {
        font-size: 0.72rem;
        font-weight: 500;
        padding: 3px 10px;
        border-radius: 6px;
        border: 1px solid var(--border);
        background: var(--white);
        color: var(--text-muted);
        cursor: pointer;
        text-decoration: none;
        transition: all 0.15s;
    }

    .dash-card-btn:hover {
        border-color: var(--navy);
        color: var(--navy);
        text-decoration: none;
    }

    .dash-card-btn.danger:hover {
        border-color: #EF4444;
        color: #EF4444;
        background: #FEE2E2;
    }

    /* ── Blog Card ── */
    .dash-blog-card {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1.25rem;
        transition: all 0.2s ease;
        display: flex;
        gap: 1rem;
        align-items: flex-start;
    }

    .dash-blog-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 6px 20px rgba(27,42,74,0.1);
    }

    .dash-blog-content { flex: 1; }

    .dash-blog-title {
        font-family: var(--font-heading);
        font-size: 1rem;
        font-weight: 600;
        color: var(--navy);
        margin: 0 0 0.4rem;
        line-height: 1.3;
    }

    .dash-blog-summary {
        font-size: 0.82rem;
        color: var(--text-muted);
        margin: 0 0 0.75rem;
        line-height: 1.5;
        display: -webkit-box;
        -webkit-line-clamp: 2;
        -webkit-box-orient: vertical;
        overflow: hidden;
    }

    .dash-blog-meta {
        display: flex;
        align-items: center;
        gap: 1rem;
    }

    .dash-status {
        font-size: 0.7rem;
        font-weight: 600;
        padding: 2px 8px;
        border-radius: 20px;
    }

    .dash-status-published {
        background: #D1FAE5;
        color: #065F46;
    }

    .dash-status-draft {
        background: #FEF3C7;
        color: #92400E;
    }

    /* ── Followers ── */
    .followers-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(200px, 1fr));
        gap: 1rem;
    }

    .follower-card {
        background: var(--white);
        border: 1px solid var(--border);
        border-radius: 12px;
        padding: 1.25rem;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.5rem;
        text-align: center;
        transition: all 0.2s;
    }

    .follower-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 4px 16px rgba(27,42,74,0.08);
    }

    .follower-avatar {
        width: 48px;
        height: 48px;
        background: var(--navy);
        border-radius: 50%;
        display: flex;
        align-items: center;
        justify-content: center;
        font-size: 1rem;
        font-weight: 700;
        color: var(--amber);
    }

    .follower-name {
        font-weight: 600;
        font-size: 0.875rem;
        color: var(--navy);
    }

    .follower-nationality {
        font-size: 0.75rem;
        color: var(--text-muted);
    }

    /* ── Empty State ── */
    .dash-empty {
        text-align: center;
        padding: 4rem 2rem;
        grid-column: 1 / -1;
    }

    .dash-empty-icon { font-size: 2.5rem; margin-bottom: 0.75rem; }

    .dash-empty h3 {
        font-size: 1.1rem;
        color: var(--navy);
        margin-bottom: 0.4rem;
    }

    .dash-empty p {
        font-size: 0.875rem;
        color: var(--text-muted);
        margin-bottom: 1.25rem;
    }

    @@media (max-width: 768px) {
        .dashboard-header { flex-direction: column; align-items: flex-start; gap: 1.25rem; }
        .dashboard-actions { align-items: flex-start; flex-direction: row; }
        .dashboard-grid { grid-template-columns: 1fr; }
        .followers-grid { grid-template-columns: repeat(2, 1fr); }
    }
</style>

<!-- Profile Header -->
<div class="dashboard-header">
    <div class="dashboard-avatar">
        @(Model.User?.FirstName?.Substring(0,1).ToUpper())@(Model.User?.LastName?.Substring(0,1).ToUpper())
    </div>

    <div class="dashboard-info">
        <h1 class="dashboard-name">@Model.User?.FirstName @Model.User?.LastName</h1>
        <p class="dashboard-email">@Model.User?.Email</p>
        <div class="dashboard-meta">
            @if (!string.IsNullOrEmpty(Model.User?.Nationality))
            {
                <span class="dashboard-meta-item">🌍 @Model.User.Nationality</span>
            }
            @if (Model.User?.Age > 0)
            {
                <span class="dashboard-meta-item">🎂 @Model.User.Age years old</span>
            }
            @if (User.IsInRole("Admin"))
            {
                <span class="dashboard-meta-item" style="background:#FEF3C7; border-color:#FCD34D; color:#92400E;">
                    ⭐ Admin
                </span>
            }
        </div>
    </div>

    <div class="dashboard-stats">
        <div class="dashboard-stat">
            <span class="dashboard-stat-num">@Model.MyNotes.Count</span>
            <div class="dashboard-stat-label">Notes</div>
        </div>
        <div class="dashboard-stat-divider"></div>
        <div class="dashboard-stat">
            <span class="dashboard-stat-num">@Model.MyBlogs.Count</span>
            <div class="dashboard-stat-label">Blogs</div>
        </div>
        <div class="dashboard-stat-divider"></div>
        <div class="dashboard-stat">
            <span class="dashboard-stat-num">@Model.Followers.Count</span>
            <div class="dashboard-stat-label">Followers</div>
        </div>
        <div class="dashboard-stat-divider"></div>
        <div class="dashboard-stat">
            <span class="dashboard-stat-num">@Model.SavedNotes.Count</span>
            <div class="dashboard-stat-label">Saved</div>
        </div>
    </div>

    <div class="dashboard-actions">
        <a class="btn-sb-primary" asp-page="/Notes/Create">+ New Note</a>
        <a class="btn-sb-ghost" asp-page="/Blogs/Create">+ New Blog</a>
    </div>
</div>

<!-- Tabs -->
<div class="dashboard-tabs">
    <button class="tab-btn active" onclick="switchTab('notes', this)">
        📝 My Notes
        <span class="tab-count">@Model.MyNotes.Count</span>
    </button>
    <button class="tab-btn" onclick="switchTab('saved', this)">
        🔖 Saved Notes
        <span class="tab-count">@Model.SavedNotes.Count</span>
    </button>
    <button class="tab-btn" onclick="switchTab('blogs', this)">
        ✍️ My Blogs
        <span class="tab-count">@Model.MyBlogs.Count</span>
    </button>
    <button class="tab-btn" onclick="switchTab('followers', this)">
        👥 Followers
        <span class="tab-count">@Model.Followers.Count</span>
    </button>
</div>

<!-- My Notes Tab -->
<div class="tab-panel active" id="tab-notes">
    <div class="dashboard-grid">
        @if (!Model.MyNotes.Any())
        {
            <div class="dash-empty">
                <div class="dash-empty-icon">📝</div>
                <h3>No notes yet</h3>
                <p>Share your knowledge by creating your first note!</p>
                <a class="btn-sb-primary" asp-page="/Notes/Create">Create a Note</a>
            </div>
        }
        else
        {
            @foreach (var note in Model.MyNotes)
            {
                <div class="dash-note-card">
                    <span class="dash-card-subject">@note.Subject</span>
                    <h3 class="dash-card-title">@note.Topic</h3>
                    <p class="dash-card-excerpt">@note.BriefExplanation</p>
                    <div class="dash-card-footer">
                        <span class="dash-card-stat">❤️ @note.Likes</span>
                        <div class="dash-card-actions">
                            <a class="dash-card-btn"
                               asp-page="/Notes/Details"
                               asp-route-id="@note.Id">View</a>
                            <a class="dash-card-btn"
                               asp-page="/Notes/Edit"
                               asp-route-id="@note.Id">Edit</a>
                            <form method="post" asp-page-handler="DeleteNote"
                                  onsubmit="return confirm('Delete this note?')"
                                  style="display:inline;">
                                <input type="hidden" name="noteId" value="@note.Id" />
                                <button type="submit" class="dash-card-btn danger">Delete</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<!-- Saved Notes Tab -->
<div class="tab-panel" id="tab-saved">
    <div class="dashboard-grid">
        @if (!Model.SavedNotes.Any())
        {
            <div class="dash-empty">
                <div class="dash-empty-icon">🔖</div>
                <h3>No saved notes</h3>
                <p>Browse notes and save the ones you want to study later.</p>
                <a class="btn-sb-primary" asp-page="/Notes/Index">Browse Notes</a>
            </div>
        }
        else
        {
            @foreach (var note in Model.SavedNotes)
            {
                <div class="dash-note-card">
                    <span class="dash-card-subject">@note.Subject</span>
                    <h3 class="dash-card-title">@note.Topic</h3>
                    <p class="dash-card-excerpt">@note.BriefExplanation</p>
                    <div class="dash-card-footer">
                        <span class="dash-card-stat">❤️ @note.Likes</span>
                        <div class="dash-card-actions">
                            <a class="dash-card-btn"
                               asp-page="/Notes/Details"
                               asp-route-id="@note.Id">View</a>
                            <form method="post" asp-page-handler="UnsaveNote"
                                  onsubmit="return confirm('Remove from saved?')"
                                  style="display:inline;">
                                <input type="hidden" name="noteId" value="@note.Id" />
                                <button type="submit" class="dash-card-btn danger">Remove</button>
                            </form>
                        </div>
                    </div>
                </div>
            }
        }
    </div>
</div>

<!-- My Blogs Tab -->
<div class="tab-panel" id="tab-blogs">
    <div style="display:flex; flex-direction:column; gap:1rem;">
        @if (!Model.MyBlogs.Any())
        {
            <div class="dash-empty">
                <div class="dash-empty-icon">✍️</div>
                <h3>No blogs yet</h3>
                <p>Share your thoughts and knowledge by writing your first blog!</p>
                <a class="btn-sb-primary" asp-page="/Blogs/Create">Write a Blog</a>
            </div>
        }
        else
        {
            @foreach (var blog in Model.MyBlogs)
            {
                <div class="dash-blog-card">
                    <div class="dash-blog-content">
                        <h3 class="dash-blog-title">@blog.Title</h3>
                        <p class="dash-blog-summary">@blog.Summary</p>
                        <div class="dash-blog-meta">
                            <span class="dash-status @(blog.PublishedAt != null ? "dash-status-published" : "dash-status-draft")">
                                @(blog.PublishedAt != null ? "Published" : "Draft")
                            </span>
                            <span class="dash-card-stat">❤️ @blog.Likes</span>
                            <span class="dash-card-stat">👁️ @blog.Views views</span>
                        </div>
                    </div>
                    <div class="dash-card-actions" style="flex-direction:column;">
                        <a class="dash-card-btn"
                           asp-page="/Blogs/Details"
                           asp-route-id="@blog.Id">View</a>
                        <a class="dash-card-btn"
                           asp-page="/Blogs/Edit"
                           asp-route-id="@blog.Id">Edit</a>
                        <form method="post" asp-page-handler="DeleteBlog"
                              onsubmit="return confirm('Delete this blog?')"
                              style="display:inline;">
                            <input type="hidden" name="blogId" value="@blog.Id" />
                            <button type="submit" class="dash-card-btn danger">Delete</button>
                        </form>
                    </div>
                </div>
            }
        }
    </div>
</div>

<!-- Followers Tab -->
<div class="tab-panel" id="tab-followers">
    <div class="followers-grid">
        @if (!Model.Followers.Any())
        {
            <div class="dash-empty">
                <div class="dash-empty-icon">👥</div>
                <h3>No followers yet</h3>
                <p>Share great notes and blogs to attract followers!</p>
            </div>
        }
        else
        {
            @foreach (var follower in Model.Followers)
            {
                <div class="follower-card">
                    <div class="follower-avatar">
                        @(follower.FirstName?.Substring(0,1).ToUpper())@(follower.LastName?.Substring(0,1).ToUpper())
                    </div>
                    <div class="follower-name">@follower.FirstName @follower.LastName</div>
                    <div class="follower-nationality">@follower.Nationality</div>
                </div>
            }
        }
    </div>
</div>

@section Scripts {
<script>
    function switchTab(name, btn) {
        document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
        document.querySelectorAll('.tab-btn').forEach(b => b.classList.remove('active'));
        document.getElementById('tab-' + name).classList.add('active');
        btn.classList.add('active');
    }
</script>
}

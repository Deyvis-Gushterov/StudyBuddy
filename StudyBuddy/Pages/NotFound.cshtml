@page
@model StudyBuddy.Pages.NotFoundModel
@{
    ViewData["Title"] = "Page Not Found";
}

<style>
    .error-page {
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        text-align: center;
        padding: 5rem 2rem;
        min-height: 60vh;
    }

    .error-code {
        font-family: var(--font-heading);
        font-size: 8rem;
        font-weight: 700;
        color: var(--navy);
        line-height: 1;
        margin-bottom: 0.5rem;
        opacity: 0.1;
        position: absolute;
        left: 50%;
        transform: translateX(-50%);
        top: 0;
        white-space: nowrap;
    }

    .error-content {
        position: relative;
        z-index: 1;
    }

    .error-icon {
        font-size: 4rem;
        margin-bottom: 1.5rem;
        display: block;
    }

    .error-title {
        font-family: var(--font-heading);
        font-size: 2rem;
        font-weight: 700;
        color: var(--navy);
        margin-bottom: 0.75rem;
    }

    .error-message {
        font-size: 1rem;
        color: var(--text-muted);
        max-width: 400px;
        line-height: 1.7;
        margin-bottom: 2rem;
    }

    .error-actions {
        display: flex;
        gap: 1rem;
        justify-content: center;
        flex-wrap: wrap;
    }

    .error-wrapper {
        position: relative;
        display: flex;
        flex-direction: column;
        align-items: center;
        justify-content: center;
        min-height: 60vh;
        overflow: hidden;
    }
</style>

<div class="error-wrapper">
    <div class="error-code">404</div>
    <div class="error-content">
        <span class="error-icon">🔍</span>
        <h1 class="error-title">Page not found</h1>
        <p class="error-message">
            The page you're looking for doesn't exist or may have been moved.
            It might have been lost between the shelves!
        </p>
        <div class="error-actions">
            <a class="btn-sb-primary" asp-page="/Index">Go Home</a>
            <a class="btn-sb-ghost" asp-page="/Notes/Index">Browse Notes</a>
        </div>
    </div>
</div>
